---
import MainLayout from '@/layouts/MainLayout.astro';
import Container from '@/components/ui/Container.astro';
import { ExtracurricularService } from '@/lib/services/extracurricular.service';
import { SchoolService } from '@/lib/services/school.service';

const ekskulItems = await ExtracurricularService.getAllExtracurriculars();
const profile = await SchoolService.getProfile();
const schoolName = profile?.schoolName || 'Institutional School';

---

<MainLayout title={`Direktori Ekstrakurikuler | ${schoolName}`}>
  <!-- 1. Hero Section -->
  <section class="relative bg-surface-variant overflow-hidden py-20 md:py-32">
    <div class="absolute inset-0 opacity-20 pointer-events-none">
      <div class="absolute top-0 right-0 w-64 h-64 bg-primary rounded-full blur-3xl -translate-y-1/2 translate-x-1/3"></div>
      <div class="absolute bottom-0 left-0 w-80 h-80 bg-secondary-container rounded-full blur-3xl translate-y-1/3 -translate-x-1/3"></div>
    </div>
    
    <Container class="relative z-10 text-center max-w-4xl mx-auto">
      <h1 class="text-2xl md:text-3xl font-bold text-on-surface font-inter tracking-tight mb-6">
        Kegiatan Ekstrakurikuler
      </h1>
      <p class="text-lg md:text-xl text-on-surface-variant leading-relaxed max-w-3xl mx-auto font-body-md">
        Kembangkan minat, bakat, dan potensi tersembunyi melalui berbagai pilihan kegiatan ekstrakurikuler yang ada di sekolah kami.
      </p>
    </Container>
  </section>

  <!-- 2. Extracurricular Directory Section -->
  <section class="py-16 bg-white min-h-[60vh]">
    <Container>
      {ekskulItems.length > 0 && (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {ekskulItems.map(ekskul => (
            <div class="bg-surface rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300 flex flex-col border border-outline-variant group">
              <div class="relative w-full aspect-video bg-surface-container-highest overflow-hidden">
                {ekskul.image ? (
                  <img 
                    src={ekskul.image} 
                    alt={ekskul.name}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    loading="lazy"
                  />
                ) : (
                  <div class="w-full h-full flex items-center justify-center text-on-surface-variant bg-primary/5">
                    <span class="text-5xl">🎖️</span>
                  </div>
                )}
                <div class="absolute top-4 left-4">
                  <span class="px-3 py-1 bg-primary text-on-primary text-xs font-semibold rounded-full shadow-sm backdrop-blur-sm">
                    {ekskul.category}
                  </span>
                </div>
              </div>
              <div class="p-6 flex flex-col flex-grow">
                <h3 class="text-xl font-bold text-on-surface font-inter mb-2 leading-tight">{ekskul.name}</h3>
                {ekskul.description && (
                  <p class="text-on-surface-variant text-sm mb-6 leading-relaxed flex-grow">{ekskul.description}</p>
                )}
                
                <div class="mt-auto space-y-3 pt-4 border-t border-outline-variant/50">
                  {ekskul.schedule && (
                    <div class="flex items-start gap-3">
                      <div class="mt-0.5 bg-surface-variant p-1.5 rounded text-primary">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                      </div>
                      <div>
                        <p class="text-xs font-semibold text-on-surface-variant uppercase tracking-wider mb-0.5">Jadwal Latihan</p>
                        <p class="text-sm font-medium text-on-surface">{ekskul.schedule}</p>
                      </div>
                    </div>
                  )}
                  {ekskul.supervisor && (
                    <div class="flex items-start gap-3">
                      <div class="mt-0.5 bg-surface-variant p-1.5 rounded text-primary">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                      </div>
                      <div>
                        <p class="text-xs font-semibold text-on-surface-variant uppercase tracking-wider mb-0.5">Pembina</p>
                        <p class="text-sm font-medium text-on-surface">{ekskul.supervisor}</p>
                      </div>
                    </div>
                  )}
                </div>
              </div>
            </div>
          ))}
        </div>
      )}
    </Container>
  </section>
</MainLayout>

---
import MainLayout from '@/layouts/MainLayout.astro';
import Container from '@/components/ui/Container.astro';
import ContactHero from '@/components/contact/ContactHero.astro';
import ContactInfoPanel from '@/components/contact/ContactInfoPanel.astro';
import ContactForm from '@/components/contact/ContactForm.astro';
import MapSection from '@/components/contact/MapSection.astro';
const profile = Astro.locals.schoolProfile;
if (!profile) return Astro.redirect('/');
---

<MainLayout title={`Hubungi Kami | ${profile.schoolName}`}>
  <!-- 1. Hero Section -->
  <ContactHero 
    title="Hubungi Kami" 
    subtitle="Ada pertanyaan atau butuh informasi lebih lanjut? Kami siap membantu Anda. Silakan hubungi kami melalui formulir di bawah atau kontak resmi kami."
  />

  <!-- 2. Contact Content Section -->
  <section class="py-16 bg-surface-container-low relative">
    <!-- Decorative element -->
    <div class="absolute top-0 right-0 w-1/3 h-full bg-soft-primary-bg/50 -skew-x-12 translate-x-1/2 pointer-events-none"></div>
    
    <Container class="relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-start">
        <!-- Left Side: Info -->
        <div class="lg:col-span-5">
          <div class="mb-8">
            <span class="text-secondary-container font-bold uppercase tracking-widest text-sm mb-4 block">Official Channels</span>
            <h2 class="font-h1 text-primary mb-6">Informasi Kontak</h2>
            <p class="text-on-surface-variant font-body-lg leading-relaxed">
              Kami terbuka untuk segala bentuk komunikasi, mulai dari informasi pendaftaran hingga saran pembangunan untuk sekolah kami.
            </p>
          </div>
          
          <ContactInfoPanel 
            address={profile.address} 
            phone={profile.phone} 
            email={profile.email} 
          />

          <div class="mt-10 p-6 bg-white rounded-[1.125rem] border border-outline-variant">
            <h4 class="font-bold text-primary mb-4 flex items-center gap-2">
              <span class="material-symbols-outlined text-secondary-container">alarm</span>
              Jam Operasional Kantor
            </h4>
            <div class="space-y-2 text-on-surface-variant font-medium">
              <p class="flex justify-between"><span>Senin - Kamis</span> <span>07:00 - 15:30</span></p>
              <p class="flex justify-between"><span>Jumat</span> <span>07:00 - 14:30</span></p>
              <p class="flex justify-between text-error"><span>Sabtu - Minggu</span> <span>Libur</span></p>
            </div>
          </div>
        </div>

        <!-- Right Side: Form -->
        <div class="lg:col-span-7">
          <ContactForm />
        </div>
      </div>
    </Container>
  </section>

  <!-- 3. Map Section -->
  <MapSection embedUrl={profile.googleMapsEmbedUrl} />
</MainLayout>

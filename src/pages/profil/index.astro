---
import MainLayout from "@/layouts/MainLayout.astro";
import ProfileHero from "@/components/profil/ProfileHero.astro";
import PrincipalMessageFull from "@/components/profil/PrincipalMessageFull.astro";
import VisionMissionFull from "@/components/profil/VisionMissionFull.astro";
import ProfileContentSection from "@/components/profil/ProfileContentSection.astro";
import Container from "@/components/ui/Container.astro";
import { StaffService } from "@/lib/services/staff.service";

const profile = Astro.locals.schoolProfile;

if (!profile) {
  return Astro.redirect("/");
}

const allStaff = await StaffService.getAllStaff();
const leaders = allStaff.filter(s => 
  s.category === 'Pimpinan' || 
  s.title.toLowerCase().includes('kepala') || 
  s.title.toLowerCase().includes('waka') ||
  s.title.toLowerCase().includes('wakil') ||
  s.title.toLowerCase().includes('sekretaris') ||
  s.title.toLowerCase().includes('bendahara')
);

const principal = leaders.find(l => 
  l.title.toLowerCase() === 'kepala sekolah' || 
  l.title.toLowerCase().startsWith('kepala sekolah')
);
const otherLeaders = leaders.filter(l => l.id !== principal?.id);
---

<MainLayout 
  title={`Profil Sekolah | ${profile.schoolName}`}
  preloadImage={profile.profileHeroImage || undefined}
>
  <!-- 1. Hero Section -->
  <ProfileHero
    title={profile.profileHeroTitle || "Profil Sekolah"}
    subtitle={profile.profileHeroSubtitle ||
      "Mengenal lebih dekat institusi pendidikan yang berdedikasi melahirkan generasi unggul dan berintegritas."}
    backgroundImage={profile.profileHeroImage ||
      "https://images.unsplash.com/photo-1541339907198-e08756ebafe3?auto=format&fit=crop&q=80&w=1920"}
  />

  <!-- 2. Sejarah / Overview -->
  <ProfileContentSection
    title="Sejarah & Filosofi Kami"
    tagline="Our Legacy"
    image={profile.historyImage ||
      "https://images.unsplash.com/photo-1523050335392-93851179ae22?auto=format&fit=crop&q=80&w=800"}
  >
    {
      profile.historyText ? (
        <div class="space-y-4">
          {profile.historyText.split("\n\n").map((p: string) => (
            <p>{p}</p>
          ))}
        </div>
      ) : (
        <p>Data sejarah belum tersedia.</p>
      )
    }
  </ProfileContentSection>

  <!-- 3. Principal Message -->
  <PrincipalMessageFull
    name={profile.principalName}
    signature={profile.principalSignature}
    message={profile.principalMessage}
    image={profile.principalImage}
    quote={profile.principalQuote || undefined}
  />

  <!-- 4. Vision & Mission -->
  <VisionMissionFull
    vision={profile.visionText}
    missions={profile.missionItems}
  />

  <!-- 5. Struktur Organisasi -->
  {leaders.length > 0 && (
    <section class="py-16 bg-surface-container-low relative">
      <Container>
        <div class="text-center mb-12">
          <span class="inline-flex bg-soft-primary-bg text-primary px-5 py-2 rounded-full text-sm font-bold uppercase tracking-widest mb-4">
            Struktur Organisasi
          </span>
          <h2 class="font-h1 text-primary">Kepemimpinan Sekolah</h2>
          <p class="text-on-surface-variant font-body-lg max-w-2xl mx-auto mt-2">
            Pimpinan sekolah yang berdedikasi mengarahkan institusi mencapai standar akademik tertinggi.
          </p>
        </div>

        <div class="w-full max-w-5xl mx-auto flex flex-col items-center relative">
          <!-- Garis penghubung vertikal (Desktop) -->
          <div class="absolute top-0 bottom-1/2 left-1/2 -translate-x-1/2 w-0.5 bg-primary/10 hidden md:block"></div>

          <!-- Kepala Sekolah (Top level) -->
          {principal && (
            <div class="relative z-10 mb-12">
              <div class="flex flex-col items-center text-center bg-white p-6 rounded-2xl border border-outline-variant shadow-sm w-72 sm:w-80 group hover:shadow-md hover:border-primary/20 transition-all duration-300">
                <div class="w-28 h-28 rounded-full overflow-hidden mb-4 border-4 border-primary/10 bg-gray-50 shadow-inner">
                  <img src={principal.image} alt={principal.name} class="w-full h-full object-cover" />
                </div>
                <h3 class="font-bold text-on-surface text-xl leading-snug">{principal.name}</h3>
                <div class="mt-2 px-3 py-1 bg-primary/5 rounded-full">
                  <p class="text-primary text-xs font-bold uppercase tracking-widest">{principal.title}</p>
                </div>
                {principal.subject && <p class="text-sm text-on-surface-variant mt-2">{principal.subject}</p>}
              </div>
              <!-- Connector line to bottom -->
              {otherLeaders.length > 0 && (
                <div class="absolute -bottom-12 left-1/2 -translate-x-1/2 w-0.5 h-12 bg-primary/20 hidden md:block"></div>
              )}
            </div>
          )}

          <!-- Wakil Kepala Sekolah & Staff Pimpinan (Second level) -->
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8 w-full relative z-10 justify-items-center">
            {otherLeaders.map(vice => (
              <div class="flex flex-col items-center text-center bg-white p-6 rounded-2xl border border-outline-variant shadow-sm w-full max-w-[280px] group hover:shadow-md hover:border-primary/20 transition-all duration-300">
                <div class="w-20 h-20 rounded-full overflow-hidden mb-4 border-2 border-primary/10 bg-gray-50">
                  <img src={vice.image} alt={vice.name} class="w-full h-full object-cover" />
                </div>
                <h4 class="font-bold text-on-surface text-base leading-snug">{vice.name}</h4>
                <p class="text-primary text-xs font-semibold mt-1 uppercase tracking-wider">{vice.title}</p>
                {vice.subject && <p class="text-[11px] text-on-surface-variant mt-1">{vice.subject}</p>}
              </div>
            ))}
          </div>
        </div>
      </Container>
    </section>
  )}

  <!-- 5. Identitas / Akreditasi -->
  <ProfileContentSection
    title="Identitas & Legalitas"
    tagline="Accreditation"
    isReversed={true}
    bgVariant="low"
    image="https://images.unsplash.com/photo-1497633762265-9d179a990aa6?auto=format&fit=crop&q=80&w=800"
  >
    <div class="flex flex-col gap-8 mt-2">
      <!-- Key Highlights -->
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
        <div class="bg-white p-4 lg:p-5 rounded-xl border border-outline-variant/60 shadow-sm flex flex-col justify-center">
          <span class="text-[10px] lg:text-xs font-bold text-on-surface-variant uppercase tracking-wider mb-1">Akreditasi</span>
          <span class="font-bold text-primary text-xl lg:text-2xl">{profile.accreditation || "A (Unggul)"}</span>
        </div>
        <div class="bg-white p-4 lg:p-5 rounded-xl border border-outline-variant/60 shadow-sm flex flex-col justify-center">
          <span class="text-[10px] lg:text-xs font-bold text-on-surface-variant uppercase tracking-wider mb-1">NPSN</span>
          <span class="font-bold text-on-surface text-xl lg:text-2xl">{profile.npsn || "12345678"}</span>
        </div>
        <div class="bg-white p-4 lg:p-5 rounded-xl border border-outline-variant/60 shadow-sm flex flex-col justify-center col-span-2 md:col-span-1">
          <span class="text-[10px] lg:text-xs font-bold text-on-surface-variant uppercase tracking-wider mb-1">Kurikulum</span>
          <span class="font-bold text-on-surface text-lg leading-tight">{profile.curriculum || "Kurikulum Merdeka"}</span>
        </div>
      </div>

      <!-- Other Details -->
      <div class="flex flex-col">
        <div class="py-4 border-b border-outline-variant/40 flex flex-col md:flex-row md:items-center justify-between gap-2">
          <span class="text-sm font-semibold text-on-surface-variant md:w-1/3">Nama Sekolah</span>
          <span class="text-base font-bold text-on-surface md:w-2/3">{profile.schoolName}</span>
        </div>
        <div class="py-4 border-b border-outline-variant/40 flex flex-col md:flex-row md:items-center justify-between gap-2">
          <span class="text-sm font-semibold text-on-surface-variant md:w-1/3">Tahun Berdiri</span>
          <span class="text-base font-medium text-on-surface md:w-2/3">{profile.foundedYear || "1995"}</span>
        </div>
        <div class="py-4 flex flex-col md:flex-row md:items-start justify-between gap-2">
          <span class="text-sm font-semibold text-on-surface-variant md:w-1/3 pt-1">Alamat</span>
          <span class="text-base font-medium text-on-surface md:w-2/3 leading-relaxed">{profile.address || "Jl. Pendidikan No. 123, Jakarta"}</span>
        </div>
      </div>
    </div>
  </ProfileContentSection>
</MainLayout>

---
import MainLayout from "@/layouts/MainLayout.astro";
import Container from "@/components/ui/Container.astro";
import SectionHeader from "@/components/ui/SectionHeader.astro";
import NewsGrid from "@/components/news/NewsGrid.astro";
import Pagination from "@/components/ui/Pagination.astro";
import { PostService } from "@/lib/services/post.service";
import { SchoolService } from "@/lib/services/school.service";
import type { NewsPost } from "@/types/homepage";

const { slug } = Astro.params;
const categories = await PostService.getAllCategories();
const isCategory = categories.map(c => c.toLowerCase()).includes((slug || '').toLowerCase());

const profile = await SchoolService.getProfile();
const schoolName = profile?.schoolName || 'Institutional School';
const schoolLogo = profile?.schoolLogo || '';

// Common variables
let post: NewsPost | null = null;
let relatedPosts: NewsPost[] = [];
let popularPosts: NewsPost[] = [];
let categoryPosts: NewsPost[] = [];
let currentPage = 1;
let totalPages = 1;
let currentCategory = '';
let articleSchema: any = null;

const cmsUrl = import.meta.env.PUBLIC_CMS_URL || "http://localhost:4321";
const formatDate = (dateStr: string) => {
  if (!dateStr) return "";
  const d = new Date(dateStr);
  if (isNaN(d.getTime())) return "";
  return d.toLocaleDateString("id-ID", {
    day: "numeric", month: "long", year: "numeric",
  });
};

// Share variables will be populated later
let shareUrl = '';
let shareTitle = '';
let shareDesc = '';
let shareImage = '';

if (isCategory) {
  currentCategory = (slug as string).toUpperCase();
  const pageParam = Astro.url.searchParams.get('page');
  currentPage = pageParam ? parseInt(pageParam) : 1;
  const limit = 6;
  categoryPosts = await PostService.getPostsByCategoryPaginated(currentCategory, currentPage, limit);
  const totalPosts = await PostService.getTotalPostsByCategory(currentCategory);
  totalPages = Math.ceil(totalPosts / limit);
} else {
  post = await PostService.getPostBySlug(slug as string);
  if (!post) {
    return Astro.redirect("/404");
  }
  relatedPosts = await PostService.getRelatedPosts(slug as string, 4);
  popularPosts = await PostService.getPopularPosts(4);
  
  shareUrl = encodeURIComponent(Astro.url.href);
  shareTitle = encodeURIComponent(post.title);
  shareDesc = encodeURIComponent(post.excerpt || '');
  shareImage = encodeURIComponent(post.image || '');

  // Construct JSON-LD NewsArticle Schema
  articleSchema = {
    "@context": "https://schema.org",
    "@type": "NewsArticle",
    "headline": post.title,
    "description": post.excerpt || post.title,
    "image": post.image ? new URL(post.image, Astro.url.origin).href : undefined,
    "datePublished": post.date ? new Date(post.date).toISOString() : undefined,
    "author": {
      "@type": "Person",
      "name": "Admin"
    },
    "publisher": {
      "@type": "School",
      "name": schoolName,
      "logo": schoolLogo ? new URL(schoolLogo, Astro.url.origin).href : undefined
    }
  };

  // Inject "You may also like" (Baca Juga) based on content length
  if (relatedPosts.length > 0 && post.content) {
    const paragraphs = post.content.split('</p>');
    const totalParagraphs = paragraphs.length;
    
    // Only inject if article is long enough
    if (totalParagraphs >= 4) {
      // Smart insertion logic: middle of content, max after 4th paragraph, min after 2nd
      const insertPosition = Math.min(4, Math.max(2, Math.floor(totalParagraphs / 2)));
      
      const relatedHtml = `
        <div class="my-5 p-4 bg-surface-container-lowest border border-outline-variant rounded-sm not-prose">
          <p class="text-on-surface-variant text-[15px] mb-4">You may also like...</p>
          <ul class="list-disc pl-6 marker:text-primary">
            ${relatedPosts.slice(0, 3).map(p => `
              <li class="pl-1">
                <a href="/berita/${p.slug}" class="text-primary font-bold text-sm hover:underline">
                  ${p.title}
                </a>
              </li>
            `).join('')}
          </ul>
        </div>
      `;
      const firstPart = paragraphs.slice(0, insertPosition).join('</p>') + '</p>';
      const secondPart = paragraphs.slice(insertPosition).join('</p>');
      post.content = firstPart + relatedHtml + secondPart;
    }
  }
}
---

{isCategory ? (
  <MainLayout title={`Kategori: ${currentCategory} | Berita | ${schoolName}`}>
    <section class="py-16 bg-white min-h-[70vh]">
      <Container>
        <SectionHeader 
          title={`Berita: ${currentCategory}`} 
          subtitle={`Kumpulan informasi terbaru untuk kategori ${currentCategory.toLowerCase()} sekolah kami.`}
        />
        
        {categoryPosts.length > 0 ? (
          <div id="berita-container" class="relative">
            <div id="berita-content">
              <NewsGrid posts={categoryPosts} />
              <Pagination 
                currentPage={currentPage} 
                totalPages={totalPages} 
                baseUrl={`/berita/${slug}`} 
              />
            </div>
          </div>
        ) : (
          <div class="text-center py-20 bg-background rounded-[1.125rem] border border-outline-variant">
            <p class="text-on-surface-variant font-medium">Belum ada berita yang diterbitkan untuk kategori ini.</p>
          </div>
        )}
      </Container>
    </section>
  </MainLayout>
) : (
  <MainLayout 
    title={`${post!.title} | Institutional School`}
    description={post!.excerpt || post!.title}
    image={post!.image || undefined}
    type="article"
    structuredData={articleSchema}
    preloadImage={post!.image || undefined}
  >
    <main class="max-w-[1200px] mx-auto px-6 md:px-12 py-12">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-16">
        <!-- Article Content (Column 1-8) -->
        <article class="md:col-span-8">
          <header class="mb-12">
            <nav class="flex flex-wrap text-xs font-medium text-on-surface-variant mb-4 items-center gap-2" aria-label="Breadcrumb">
              <a href="/" class="hover:text-primary transition-colors">Home</a>
              <span>/</span>
              <a href="/berita" class="hover:text-primary transition-colors">Berita</a>
              <span>/</span>
              <a href={`/berita/${(post!.category || 'berita').toLowerCase()}`} class="hover:text-primary transition-colors uppercase">
                {post!.category || "Berita"}
              </a>
            </nav>
            <h1 class="text-2xl md:text-3xl font-extrabold text-on-surface mb-6">
              {post!.title}
            </h1>
            
            <div class="flex flex-wrap gap-3 mb-6 items-center">
              <a href={`/berita/${(post!.category || 'berita').toLowerCase()}`}
                class="bg-surface-container-highest text-primary text-xs font-bold px-3 py-1.5 rounded-lg uppercase tracking-wider hover:bg-primary hover:text-white transition-colors"
              >
                {post!.category || "Berita"}
              </a>
              <span class="text-on-surface-variant text-sm py-1 font-medium">
                {formatDate(post!.date)}
              </span>
            </div>

            <!-- Social Share Buttons -->
            <div class="flex flex-wrap items-center gap-2">
              <a href={`https://www.facebook.com/sharer/sharer.php?u=${shareUrl}`} target="_blank" rel="noopener noreferrer" class="w-8 h-8 rounded-full flex items-center justify-center text-white bg-[#3b5998] hover:scale-110 transition-transform" aria-label="Share on Facebook">
                <svg fill="currentColor" viewBox="0 0 24 24" class="w-4 h-4"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"></path></svg>
              </a>
              <a href={`https://twitter.com/intent/tweet?url=${shareUrl}&text=${shareTitle}`} target="_blank" rel="noopener noreferrer" class="w-8 h-8 rounded-full flex items-center justify-center text-white bg-[#00acee] hover:scale-110 transition-transform" aria-label="Share on Twitter">
                <svg fill="currentColor" viewBox="0 0 24 24" class="w-4 h-4"><path d="M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2c9 5 20 0 20-11.5a4.5 4.5 0 00-.08-.83A7.72 7.72 0 0023 3z"></path></svg>
              </a>
              <a href={`https://pinterest.com/pin/create/button/?url=${shareUrl}&media=${shareImage}&description=${shareTitle}`} target="_blank" rel="noopener noreferrer" class="w-8 h-8 rounded-full flex items-center justify-center text-white bg-[#cb2027] hover:scale-110 transition-transform" aria-label="Share on Pinterest">
                <svg fill="currentColor" viewBox="0 0 24 24" class="w-4 h-4"><path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.957 1.406-5.957s-.359-.72-.359-1.781c0-1.663.967-2.911 2.168-2.911 1.024 0 1.518.769 1.518 1.688 0 1.029-.653 2.567-.992 3.992-.285 1.193.6 2.165 1.775 2.165 2.128 0 3.768-2.245 3.768-5.487 0-2.861-2.063-4.869-5.008-4.869-3.41 0-5.409 2.562-5.409 5.199 0 1.033.394 2.143.889 2.741.099.12.112.225.085.345-.09.375-.293 1.199-.334 1.363-.053.225-.172.271-.401.165-1.495-.69-2.433-2.878-2.433-4.646 0-3.776 2.748-7.252 7.92-7.252 4.158 0 7.392 2.967 7.392 6.923 0 4.135-2.607 7.462-6.233 7.462-1.214 0-2.354-.629-2.758-1.379l-.749 2.848c-.269 1.045-1.004 2.352-1.498 3.146 1.123.345 2.306.535 3.55.535 6.607 0 11.985-5.365 11.985-11.987C23.97 5.366 18.602 0 12.017 0z"></path></svg>
              </a>
              <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${shareUrl}`} target="_blank" rel="noopener noreferrer" class="w-8 h-8 rounded-full flex items-center justify-center text-white bg-[#0077b5] hover:scale-110 transition-transform" aria-label="Share on LinkedIn">
                <svg fill="currentColor" viewBox="0 0 24 24" class="w-4 h-4"><path d="M4.98 3.5c0 1.381-1.11 2.5-2.48 2.5s-2.48-1.119-2.48-2.5c0-1.38 1.11-2.5 2.48-2.5s2.48 1.12 2.48 2.5zm.02 4.5h-5v16h5v-16zm7.982 0h-4.968v16h4.969v-8.399c0-4.67 6.029-5.052 6.029 0v8.399h4.988v-10.131c0-7.88-8.922-7.593-11.018-3.714v-2.155z"></path></svg>
              </a>
              <a href={`https://www.tumblr.com/share/link?url=${shareUrl}&name=${shareTitle}&description=${shareDesc}`} target="_blank" rel="noopener noreferrer" class="w-8 h-8 rounded-full flex items-center justify-center text-white bg-[#35465c] hover:scale-110 transition-transform" aria-label="Share on Tumblr">
                <svg fill="currentColor" viewBox="0 0 24 24" class="w-4 h-4"><path d="M14.563 24c-5.093 0-7.031-3.756-7.031-6.411V9.747H5.116V6.648c3.63-1.313 4.512-4.596 4.71-6.469C9.84.051 9.941 0 9.999 0h3.517v6.114h4.801v3.633h-4.82v7.47c.016 1.001.375 2.271 2.22 2.271 1.536 0 2.571-.415 2.8-.546l1.453 3.232c-1.417.817-3.763 1.826-5.407 1.826z"></path></svg>
              </a>
              <a href={`https://wa.me/?text=${shareTitle}%20${shareUrl}`} target="_blank" rel="noopener noreferrer" class="w-8 h-8 rounded-full flex items-center justify-center text-white bg-[#25d366] hover:scale-110 transition-transform" aria-label="Share on WhatsApp">
                <svg fill="currentColor" viewBox="0 0 24 24" class="w-4.5 h-4.5"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"></path></svg>
              </a>
              <a href={`https://t.me/share/url?url=${shareUrl}&text=${shareTitle}`} target="_blank" rel="noopener noreferrer" class="w-8 h-8 rounded-full flex items-center justify-center text-white bg-[#0088cc] hover:scale-110 transition-transform" aria-label="Share on Telegram">
                <svg fill="currentColor" viewBox="0 0 24 24" class="w-4 h-4"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.64 6.8c-.15 1.58-.8 5.42-1.13 7.19-.14.75-.42 1-.68 1.03-.58.05-1.02-.38-1.58-.75-.88-.58-1.38-.94-2.23-1.5-.99-.65-.35-1.01.22-1.59.15-.15 2.71-2.48 2.76-2.69a.2.2 0 00-.05-.18c-.06-.05-.14-.03-.21-.02-.09.02-1.49.95-4.22 2.79-.4.27-.76.41-1.08.4-.36-.01-1.04-.2-1.55-.37-.63-.21-1.12-.33-1.08-.7.02-.19.27-.39.75-.6 2.93-1.28 4.88-2.12 5.86-2.53 2.79-1.16 3.37-1.36 3.75-1.36.08 0 .27.02.39.12.1.08.13.19.14.27-.01.06.01.24 0 .24z"></path></svg>
              </a>
            </div>
          </header>

          <div class="mb-12 overflow-hidden rounded-2xl bg-surface-container">
            <img
              alt={post!.title}
              class="w-full aspect-video object-cover"
              src={post!.image || "https://via.placeholder.com/1200x600"}
              loading="eager"
              fetchpriority="high"
            />
          </div>

          <!-- Table of Contents (Auto-generated via JS) -->
          <div class="mb-10">
            <details class="bg-gray-200 rounded-md group inline-block min-w-[280px] max-w-[384px]" id="toc-container" style="display: none;">
              <summary class="px-5 py-3 text-sm text-gray-600 cursor-pointer select-none flex justify-between items-center gap-4 transition-all">
                <span>Table of content</span>
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-gray-400 transition-transform group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
              </summary>
              <div class="px-5 pb-4 text-sm">
                <ul id="toc-list" class="space-y-2 text-gray-600 font-normal list-disc pl-4"></ul>
              </div>
            </details>
          </div>

          <div
            class="prose-content font-body-lg text-lg text-on-surface leading-[32px] font-medium
            [&>p]:mb-8
            [&>blockquote]:border-l-4 [&>blockquote]:border-primary [&>blockquote]:pl-6 [&>blockquote]:italic [&>blockquote]:my-10 [&>blockquote]:text-primary [&>blockquote]:font-medium
            [&>h2]:text-3xl [&>h2]:font-bold [&>h2]:text-on-surface [&>h2]:mb-6 [&>h2]:mt-12
            [&>h3]:text-2xl [&>h3]:font-bold [&>h3]:text-on-surface [&>h3]:mb-4 [&>h3]:mt-10
            [&>ul]:list-disc [&>ul]:pl-6 [&>ul]:mb-8 [&>ul>li]:mb-2
            [&>ol]:list-decimal [&>ol]:pl-6 [&>ol]:mb-8 [&>ol>li]:mb-2
            [&>a]:text-primary [&>a]:underline hover:[&>a]:text-primary-container
            [&>strong]:text-on-surface [&>strong]:font-bold"
          >
            <Fragment set:html={post!.content} />
          </div>

          <div class="mt-16 pt-8 border-t border-outline-variant">
            <div class="flex items-center mb-6">
              <h3 class="text-sm font-bold text-on-surface-variant uppercase tracking-widest mr-4">Related Post</h3>
              <div class="h-[1px] bg-outline-variant flex-1"></div>
              <div class="h-[2px] bg-primary w-8 -ml-8 relative z-10"></div>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              {relatedPosts.slice(0, 4).map((p) => (
                <div class="bg-surface-container-lowest border border-outline-variant rounded-md overflow-hidden flex flex-col group">
                  <a href={`/berita/${p.slug}`} class="block overflow-hidden aspect-[16/9]">
                    <img src={p.image || "https://via.placeholder.com/600x400"} alt={p.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
                  </a>
                  <div class="p-5 flex flex-col flex-1">
                    <a href={`/berita/${p.slug}`} class="text-[17px] font-bold text-on-surface group-hover:text-primary transition-colors line-clamp-2 mb-4 leading-snug">
                      {p.title}
                    </a>
                    <div class="mt-auto flex items-center gap-4 text-[13px] text-on-surface-variant">
                      <span class="flex items-center gap-1.5">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                        Admin
                      </span>
                      <span class="flex items-center gap-1.5">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                        {formatDate(p.date)}
                      </span>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </article>

        <!-- Sidebar (Column 9-12) -->
        <aside class="md:col-span-4 space-y-10 mt-12 md:mt-0">
          <!-- Popular Posts -->
          {
            popularPosts && popularPosts.length > 0 && (
              <div class="space-y-4">
                <h4 class="text-xs font-bold text-on-surface-variant uppercase tracking-widest border-b border-surface-container-highest pb-4 mb-6">
                  Popular Posts
                </h4>
                {popularPosts.map((popPost, index) => (
                  <a
                    class="group flex gap-4 pb-4 border-b border-surface-container-highest/50 last:border-0 items-center"
                    href={popPost.href}
                  >
                    <div class="w-20 h-20 shrink-0 rounded-md overflow-hidden bg-surface-container relative">
                      <div class="absolute top-0 left-0 bg-primary text-on-primary text-[10px] font-bold px-1.5 py-0.5 z-10 rounded-br-md">
                        #{index + 1}
                      </div>
                      <img src={popPost.image || "https://via.placeholder.com/150"} alt={popPost.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
                    </div>
                    <div class="flex-grow flex flex-col justify-center">
                      <span class="text-[10px] font-bold text-primary tracking-wider uppercase mb-1">
                        {popPost.category || "Berita"}
                      </span>
                      <h5 class="text-sm font-bold text-on-surface group-hover:text-primary transition-colors leading-[1.3] line-clamp-2 mb-1">
                        {popPost.title}
                      </h5>
                      <p class="text-[11px] font-medium text-on-surface-variant">
                        {formatDate(popPost.date)}
                      </p>
                    </div>
                  </a>
                ))}
              </div>
            )
          }

          <!-- Recent Posts -->
          {
            relatedPosts && relatedPosts.length > 0 && (
              <div class="space-y-4 pt-4">
                <h4 class="text-xs font-bold text-on-surface-variant uppercase tracking-widest border-b border-surface-container-highest pb-4 mb-6">
                  Recent Posts
                </h4>
                {relatedPosts.map((relPost) => (
                  <a
                    class="group flex gap-4 pb-4 border-b border-surface-container-highest/50 last:border-0 items-center"
                    href={relPost.href}
                  >
                    <div class="w-20 h-20 shrink-0 rounded-md overflow-hidden bg-surface-container">
                      <img src={relPost.image || "https://via.placeholder.com/150"} alt={relPost.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
                    </div>
                    <div class="flex-grow flex flex-col justify-center">
                      <span class="text-[10px] font-bold text-primary tracking-wider uppercase mb-1">
                        {relPost.category || "Berita"}
                      </span>
                      <h5 class="text-sm font-bold text-on-surface group-hover:text-primary transition-colors leading-[1.3] line-clamp-2 mb-1">
                        {relPost.title}
                      </h5>
                      <p class="text-[11px] font-medium text-on-surface-variant">
                        {formatDate(relPost.date)}
                      </p>
                    </div>
                  </a>
                ))}
              </div>
            )
          }
        </aside>
      </div>
    </main>
    
    <script is:inline define:vars={{ postId: post!.id, cmsApiUrl: cmsUrl }}>
      // Fire-and-forget view increment
      (function () {
        try {
          navigator.sendBeacon
            ? navigator.sendBeacon(cmsApiUrl + "/api/posts/" + postId + "/view", "")
            : fetch(cmsApiUrl + "/api/posts/" + postId + "/view", {
                method: "POST",
                keepalive: true,
              }).catch(function () {});
        } catch (e) {}
      })();
      
      // Auto-generate Table of Contents
      document.addEventListener('DOMContentLoaded', function() {
        var prose = document.querySelector('.prose-content');
        var tocContainer = document.getElementById('toc-container');
        var tocList = document.getElementById('toc-list');
        
        if (prose && tocContainer && tocList) {
          var headings = prose.querySelectorAll('h2, h3');
          if (headings.length > 0) {
            tocContainer.style.display = 'block'; // Show TOC
            
            headings.forEach(function(heading, index) {
              if (!heading.id) {
                heading.id = 'heading-' + index;
              }
              
              var li = document.createElement('li');
              var a = document.createElement('a');
              a.href = '#' + heading.id;
              a.textContent = heading.textContent;
              a.className = 'hover:text-primary transition-colors block';
              
              if (heading.tagName.toLowerCase() === 'h3') {
                li.className = 'pl-4 border-l-2 border-outline-variant';
              }
              
              li.appendChild(a);
              tocList.appendChild(li);
            });
          }
        }
      });
    </script>
  </MainLayout>
)}

{isCategory && (
  <script>
    function setupAjaxPagination() {
      const container = document.getElementById('berita-container');
      if (!container) return;
      
      container.addEventListener('click', async (e) => {
        const link = (e.target as HTMLElement).closest('.pagination-link') as HTMLAnchorElement;
        
        if (link && link.href) {
          e.preventDefault();
          
          const url = link.href;
          
          try {
            const response = await fetch(url);
            const html = await response.text();
            
            const parser = new DOMParser();
            const doc = parser.parseFromString(html, 'text/html');
            const newContent = doc.getElementById('berita-content');
            
            if (newContent) {
              const oldContent = document.getElementById('berita-content');
              if (oldContent) {
                oldContent.innerHTML = newContent.innerHTML;
              }
              
              window.history.pushState({}, '', url);
              container.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
          } catch (error) {
            console.error('Failed to load pagination:', error);
            window.location.href = url;
          }
        }
      });
    }

    setupAjaxPagination();
  </script>
)}

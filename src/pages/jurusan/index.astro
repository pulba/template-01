---
import MainLayout from '@/layouts/MainLayout.astro';
import Container from '@/components/ui/Container.astro';
import { MajorService } from '@/lib/services/major.service';
import { SchoolService } from '@/lib/services/school.service';

const majors = await MajorService.getActiveMajors();
const profile = await SchoolService.getProfile();
const schoolName = profile?.schoolName || 'Institutional School';
const term = Astro.locals.terminology?.dictionary;
const majorPlural = term?.major?.plural || 'Jurusan';
const majorLong = term?.major?.long || 'Program Keahlian';
---

<MainLayout title={`${majorPlural} | ${schoolName}`}>
  <!-- 1. Hero Section -->
  <section class="relative bg-surface-variant overflow-hidden py-20 md:py-32">
    <div class="absolute inset-0 opacity-20 pointer-events-none">
      <div class="absolute top-0 right-0 w-64 h-64 bg-primary rounded-full blur-3xl -translate-y-1/2 translate-x-1/3"></div>
      <div class="absolute bottom-0 left-0 w-80 h-80 bg-secondary-container rounded-full blur-3xl translate-y-1/3 -translate-x-1/3"></div>
    </div>
    
    <Container class="relative z-10 text-center max-w-4xl mx-auto">
      <span class="inline-block px-4 py-1.5 bg-primary/10 text-primary text-xs font-semibold rounded-full tracking-wider uppercase mb-4">
        {majorLong}
      </span>
      <h1 class="text-3xl md:text-5xl font-bold text-on-surface font-inter tracking-tight mb-6">
        Pilihan {majorPlural} Terbaik
      </h1>
      <p class="text-base md:text-lg text-on-surface-variant leading-relaxed max-w-2xl mx-auto font-medium">
        Temukan program keahlian yang sesuai dengan minat, bakat, dan cita-cita masa depan Anda. Kami menyediakan kurikulum relevan yang terintegrasi dengan dunia kerja.
      </p>
    </Container>
  </section>

  <!-- 2. Majors Grid Section -->
  <section class="py-16 bg-white min-h-[50vh]">
    <Container>
      {majors.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {majors.map((item) => (
            <div class="h-full bg-surface rounded-2xl overflow-hidden shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-300 flex flex-col border border-outline-variant group">
              <!-- Thumbnail -->
              <a href={`/jurusan/${item.slug}`} class="relative block w-full aspect-video overflow-hidden bg-surface-container-highest">
                {item.thumbnail ? (
                  <img 
                    src={item.thumbnail} 
                    alt={item.name}
                    class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    loading="lazy"
                  />
                ) : (
                  <div class="absolute inset-0 w-full h-full flex items-center justify-center text-on-surface-variant bg-primary/5">
                    <span class="text-5xl">📖</span>
                  </div>
                )}
                <div class="absolute top-4 left-4 z-10">
                  <span class="px-3 py-1 bg-surface/90 text-primary text-xs font-semibold rounded-full shadow-sm backdrop-blur-sm">
                    {term?.major?.short || 'Jurusan'}
                  </span>
                </div>
              </a>
              
              <!-- Content -->
              <div class="p-6 flex flex-col flex-grow">
                <h3 class="text-xl font-bold text-on-surface font-inter mb-2 leading-tight line-clamp-2 min-h-[3.5rem]">
                  <a href={`/jurusan/${item.slug}`} class="hover:text-primary transition-colors">
                    {item.name}
                  </a>
                </h3>
                <p class="text-on-surface-variant text-sm mb-6 leading-relaxed line-clamp-3 min-h-[4.5rem]">
                  {item.excerpt || ""}
                </p>
                
                <div class="mt-auto pt-4 border-t border-outline-variant/50 flex justify-between items-center">
                  <a 
                    href={`/jurusan/${item.slug}`}
                    class="inline-flex items-center gap-1.5 text-sm font-semibold text-primary hover:text-primary-hover group/link transition-colors"
                  >
                    Selengkapnya
                    <svg 
                      xmlns="http://www.w3.org/2000/svg" 
                      width="16" 
                      height="16" 
                      viewBox="0 0 24 24" 
                      fill="none" 
                      stroke="currentColor" 
                      stroke-width="2.5" 
                      stroke-linecap="round" 
                      stroke-linejoin="round"
                      class="transition-transform duration-200 group-hover/link:translate-x-1"
                    >
                      <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                    </svg>
                  </a>
                </div>
              </div>
            </div>
          ))}
        </div>
      ) : (
        <div class="text-center py-16 max-w-[448px] mx-auto">
          <span class="text-6xl mb-4 block">🔍</span>
          <h3 class="text-lg font-bold text-on-surface mb-2">Belum Ada Jurusan</h3>
          <p class="text-sm text-on-surface-variant">
            Data jurusan saat ini belum ditambahkan atau sedang dalam proses pembaruan oleh administrator.
          </p>
        </div>
      )}
    </Container>
  </section>
</MainLayout>

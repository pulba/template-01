---
// This is an SSR page. It runs entirely on the server.
import { AdmissionService } from '@/lib/services/admission.service';

const regNumber = Astro.url.searchParams.get('regNumber');
const birthDate = Astro.url.searchParams.get('birthDate');

if (!regNumber || !birthDate) {
  return Astro.redirect('/pendaftaran/status');
}

const cmsUrl = import.meta.env.PUBLIC_CMS_URL || 'http://localhost:4321';

// Fetch registration data server-side
let data = null;
let error = null;

try {
  const url = new URL(`${cmsUrl}/api/admissions/registrations/lookup`);
  url.searchParams.set('number', regNumber);
  url.searchParams.set('birthDate', birthDate);

  const res = await fetch(url.toString(), {
    headers: { 'Accept': 'application/json' }
  });

  const raw = await res.json();
  if (res.ok) {
    data = raw;
  } else {
    error = raw.error || "Data tidak ditemukan.";
  }
} catch (e) {
  error = "Terjadi kesalahan koneksi server.";
}

if (error || !data) {
  // If failed, render a simple error page that auto-redirects
  return new Response(`
    <!DOCTYPE html>
    <html>
      <head>
        <title>Error - Data Tidak Ditemukan</title>
        <meta http-equiv="refresh" content="3;url=/pendaftaran/status">
        <style>body { font-family: sans-serif; padding: 40px; text-align: center; background: #f8fafc; }</style>
      </head>
      <body>
        <h2 style="color: #ef4444;">Pencarian Gagal</h2>
        <p>${error || 'Data pendaftaran tidak valid.'}</p>
        <p><a href="/pendaftaran/status">Kembali ke halaman status...</a></p>
      </body>
    </html>
  `, { status: 404, headers: { 'Content-Type': 'text/html' }});
}

// ─── Render Printable Proof ───
const profile = Astro.locals.schoolProfile;
const schoolName = profile?.schoolName || 'SMA NEGERI 1 LAMBAR';
const logoUrl = profile?.schoolLogo || '/assets/logo.png';
const address = profile?.address || 'Jl. Pendidikan Raya No. 1, Menteng, Jakarta Pusat';

const nowStr = new Date().toLocaleDateString('id-ID', {
  weekday: 'long', year: 'numeric', month: 'long', day: 'numeric',
  hour: '2-digit', minute: '2-digit'
}) + ' WIB';

const statusTheme: Record<string, string> = {
  pending: '#d97706',
  verified: '#2563eb',
  interview: '#9333ea',
  accepted: '#16a34a',
  rejected: '#dc2626',
  waitlisted: '#475569',
};
const statusColor = statusTheme[data.status] || statusTheme.pending;
---

<!DOCTYPE html>
<html lang="id">
<head>
  <title>Bukti Pendaftaran - {data.registrationNumber}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0&display=swap" rel="stylesheet">
  <style define:vars={{ primaryColor: profile?.themeColorPrimary || '#00236f', fontFamily: profile?.themeFontFamily || 'Plus Jakarta Sans' }}>
    :root {
      --primary: var(--primaryColor);
      --border: #e2e8f0;
      --text: #334155;
      --bg: #ffffff;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: var(--fontFamily), system-ui, -apple-system, sans-serif;
      color: var(--text);
      background-color: #f1f5f9;
      line-height: 1.5;
      padding: 2rem;
    }
    .print-container {
      max-width: 800px;
      margin: 0 auto;
      background: var(--bg);
      padding: 3rem;
      border-radius: 12px;
      box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);
    }
    .header {
      display: flex;
      align-items: center;
      gap: 1.5rem;
      border-bottom: 3px solid var(--primary);
      padding-bottom: 1.5rem;
      margin-bottom: 2rem;
    }
    .logo { width: 80px; height: 80px; object-fit: contain; }
    .school-info h1 { color: var(--primary); font-size: 1.5rem; font-weight: 800; margin-bottom: 0.25rem; }
    .school-info p { font-size: 0.875rem; color: #64748b; }
    
    .title {
      text-align: center;
      margin-bottom: 2.5rem;
    }
    .title h2 { font-size: 1.25rem; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.5rem; color: var(--primary); }
    .reg-number {
      display: inline-block;
      font-family: monospace;
      font-size: 1.5rem;
      font-weight: bold;
      background: #f8fafc;
      border: 2px dashed #cbd5e1;
      padding: 0.5rem 1.5rem;
      border-radius: 8px;
    }

    .info-grid {
      display: grid;
      grid-template-columns: 150px 1fr;
      gap: 1rem;
      margin-bottom: 2rem;
    }
    .label { font-weight: 600; color: #475569; font-size: 0.875rem; }
    .value { font-weight: 500; color: var(--primary); font-size: 1rem; }
    .value.status { 
      font-weight: 700;
    }

    .footer {
      margin-top: 4rem;
      padding-top: 2rem;
      border-top: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      font-size: 0.875rem;
      color: #64748b;
    }
    .footer-left { max-width: 60%; }
    .signature-area {
      text-align: center;
    }
    .signature-area .line {
      width: 150px;
      border-bottom: 1px solid var(--text);
      margin-top: 4rem;
      margin-bottom: 0.5rem;
    }

    /* Professional Toolbar */
    .print-toolbar {
      position: sticky;
      top: 0;
      left: 0;
      right: 0;
      background: #ffffff;
      border-bottom: 1px solid var(--border);
      padding: 0.75rem 2rem;
      z-index: 100;
      box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.05);
      margin-bottom: 2rem;
    }
    .toolbar-content {
      max-width: 800px;
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 0.375rem;
      text-decoration: none;
      color: #64748b;
      font-weight: 600;
      font-size: 0.875rem;
      transition: color 0.2s ease;
      flex: 1;
      justify-content: flex-start;
    }
    .back-link:hover {
      color: var(--primary);
    }
    .toolbar-title {
      font-weight: 700;
      font-size: 0.95rem;
      color: var(--primary);
      text-align: center;
      flex: 2;
    }
    .actions-wrapper {
      display: flex;
      justify-content: flex-end;
      flex: 1;
    }
    .btn-print-action {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: var(--primary);
      color: white;
      border: none;
      padding: 0.5rem 1.5rem;
      border-radius: 9999px;
      font-weight: 600;
      cursor: pointer;
      font-size: 0.875rem;
      font-family: inherit;
      transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
      box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    }
    .btn-print-action:hover {
      opacity: 0.9;
      transform: translateY(-1px);
      box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
    }
    .btn-print-action:active {
      transform: translateY(0);
      opacity: 0.95;
    }

    @media print {
      body { background: white; padding: 0; }
      .print-container { box-shadow: none; padding: 0; max-width: 100%; border-radius: 0; }
      .print-toolbar { display: none !important; }
      @page {
        size: A4 portrait;
        margin: 1.5cm;
      }
    }
  </style>
</head>
<body>
  
  <div class="print-toolbar no-print">
    <div class="toolbar-content">
      <a href={`/pendaftaran/status?reg=${encodeURIComponent(regNumber)}&birthDate=${encodeURIComponent(birthDate)}`} class="back-link">
        <span class="material-symbols-outlined text-lg">arrow_back</span>
        Kembali ke Status
      </a>
      <div class="toolbar-title">Pratinjau Cetak Bukti Pendaftaran</div>
      <div class="actions-wrapper">
        <button class="btn-print-action" onclick="window.print()">
          <span class="material-symbols-outlined text-lg">print</span>
          Cetak Bukti
        </button>
      </div>
    </div>
  </div>

  <div class="print-container">
    <div class="header">
      <img src={logoUrl} alt="Logo Sekolah" class="logo" />
      <div class="school-info">
        <h1 class="text-2xl md:text-3xl font-bold">{schoolName}</h1>
        <p>{address}</p>
        <p>Panitia Penerimaan Peserta Didik Baru (PPDB)</p>
      </div>
    </div>

    <div class="title">
      <h2>Bukti Registrasi PPDB Online</h2>
      <div class="reg-number">{data.registrationNumber}</div>
    </div>

    <div class="info-grid">
      <div class="label">Nama Lengkap</div>
      <div class="value">{data.fullName}</div>

      <div class="label">Program</div>
      <div class="value">{data.program}</div>

      {data.major && (
        <>
          <div class="label">Jurusan</div>
          <div class="value">{data.major}</div>
        </>
      )}

      <div class="label">Waktu Daftar</div>
      <div class="value">{new Date(data.registeredAt).toLocaleDateString('id-ID', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' })} WIB</div>

      <div class="label">Status Saat Ini</div>
      <div class="value status" style={`color: ${statusColor};`}>{data.statusLabel}</div>
    </div>

    <div class="footer">
      <div class="footer-left">
        <strong>Catatan Penting & Syarat Verifikasi Fisik:</strong>
        <p style="margin-top: 0.5rem; line-height: 1.6; font-size: 0.825rem; font-weight: 500;">
          Silakan bawa berkas fisik berikut untuk proses verifikasi dokumen ke sekolah:
        </p>
        <ul style="margin-top: 0.35rem; margin-left: 1.25rem; list-style-type: disc; font-size: 0.8rem; line-height: 1.6; color: #475569;">
          {profile?.ppdbNotes ? (
            profile.ppdbNotes.split('\n').filter((line: string) => line.trim() !== '').map((line: string) => (
              <li>{line}</li>
            ))
          ) : (
            <>
              <li>Cetak Bukti Registrasi Online ini (1 lembar)</li>
              <li>Fotokopi Ijazah / Surat Keterangan Lulus (SKL) dilegalisir (1 lembar)</li>
              <li>Fotokopi Akta Kelahiran & Kartu Keluarga (masing-masing 1 lembar)</li>
              <li>Pasfoto berwarna terbaru ukuran 3x4 (2 lembar)</li>
              <li>Fotokopi KIP/KKS/PKH (khusus jalur afirmasi, jika ada)</li>
            </>
          )}
        </ul>
      </div>
      <div class="signature-area">
        <p>Dicetak pada:</p>
        <p style="font-weight: 500;">{nowStr}</p>
        <div class="line"></div>
        <p>Panitia PPDB</p>
      </div>
    </div>
  </div>

</body>
</html>

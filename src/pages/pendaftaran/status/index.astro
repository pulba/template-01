---
import MainLayout from '@/layouts/MainLayout.astro';
import Container from '@/components/ui/Container.astro';

const profile = Astro.locals.schoolProfile;
const schoolName = profile?.schoolName || 'Sekolah';
const cmsUrl = import.meta.env.PUBLIC_CMS_URL || 'http://localhost:4321';
---

<MainLayout title={`Cek Status Pendaftaran | ${schoolName}`} description="Lacak status pendaftaran peserta didik baru Anda.">
  <section class="py-10 md:py-16 bg-surface-container-low min-h-[70vh] relative">
    <div class="absolute top-0 left-0 w-full h-full overflow-hidden pointer-events-none">
      <div class="absolute top-0 left-1/4 w-1/2 h-full bg-soft-primary-bg skew-x-12 opacity-50"></div>
    </div>

    <Container class="relative z-10">
      <div class="max-w-2xl mx-auto">
        <!-- Header -->
        <div class="text-center mb-10">
          <span class="inline-flex items-center gap-2 bg-primary/10 text-primary border border-primary/20 rounded-full px-4 py-1.5 text-sm font-medium mb-6">
            <span class="material-symbols-outlined text-base">search</span>
            Pelacakan Status
          </span>
          <h1 class="text-2xl md:text-3xl font-bold text-on-surface mb-4">Cek Status Pendaftaran</h1>
          <p class="text-on-surface-variant font-body-lg">
            Masukkan Nomor Pendaftaran untuk melihat status seleksi Anda.
          </p>
        </div>

        <!-- Form Card -->
        <form id="tracking-form" class="bg-white rounded-[1.125rem] shadow-sm border border-outline-variant p-8 md:p-10 mb-8 space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="space-y-1">
              <label for="regNumber" class="text-xs font-bold text-primary uppercase tracking-widest ml-1 block mb-2">Nomor Pendaftaran <span class="text-error">*</span></label>
              <input 
                type="text" 
                id="regNumber" 
                name="regNumber" 
                required 
                maxlength="15"
                placeholder="Contoh: REG-2026-0001"
                class="w-full bg-white border border-outline-variant focus:border-primary/30 rounded-full py-4 px-5 transition-all font-medium outline-none text-on-surface"
              />
            </div>

            <div class="space-y-1">
              <label for="birthDate" class="text-xs font-bold text-primary uppercase tracking-widest ml-1 block mb-2">Tanggal Lahir Calon Siswa <span class="text-error">*</span></label>
              <input 
                type="date" 
                id="birthDate" 
                name="birthDate" 
                required 
                class="w-full bg-white border border-outline-variant focus:border-primary/30 rounded-full py-4 px-5 transition-all font-medium outline-none text-on-surface"
              />
            </div>
          </div>

          <div id="tracking-error" class="hidden bg-error-container text-on-error-container p-4 rounded-xl text-sm font-medium"></div>

          <button 
            type="submit" 
            id="tracking-submit"
            class="w-full bg-primary text-on-primary font-semibold py-4 rounded-full active:scale-[0.95] transition-all flex items-center justify-center gap-3 group text-base cursor-pointer"
          >
            <span id="submit-text">Cari Data Pendaftaran</span>
            <span id="submit-icon" class="material-symbols-outlined group-hover:translate-x-1 transition-transform">search</span>
            <span id="submit-spinner" class="hidden">
              <svg class="animate-spin h-5 w-5" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" class="opacity-25"></circle><path d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z" fill="currentColor" class="opacity-75"></path></svg>
            </span>
          </button>
        </form>

        <!-- Result Card (Hidden initially) -->
        <div id="tracking-result" class="hidden bg-white rounded-[1.125rem] shadow-sm border border-outline-variant">
          <div class="bg-primary/5 border-b border-outline-variant p-6 md:p-8 text-center relative rounded-t-[1.125rem]">
            <span id="status-icon-wrapper" class="absolute top-0 right-8 -translate-y-1/2 w-16 h-16 rounded-full flex items-center justify-center border-4 border-white shadow-sm">
              <span id="status-icon" class="material-symbols-outlined text-3xl"></span>
            </span>
            <p class="text-xs font-bold text-primary/60 uppercase tracking-widest mb-2">Status Saat Ini</p>
            <h2 id="result-status-label" class="text-2xl md:text-3xl font-bold tracking-tight mb-2"></h2>
            <div id="result-admin-note" class="hidden inline-flex items-center gap-2 bg-white/60 px-4 py-2 rounded-lg text-sm text-on-surface-variant font-medium mt-2 max-w-[512px] mx-auto text-left">
            </div>
          </div>
          <div class="p-6 md:p-8">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
              <div class="bg-surface-container-low/50 p-4 rounded-2xl border border-outline-variant/30">
                <p class="text-xs font-bold text-primary/60 uppercase tracking-wider mb-1">Nama Peserta</p>
                <p id="result-name" class="font-bold text-on-surface text-base md:text-lg"></p>
              </div>
              <div class="bg-surface-container-low/50 p-4 rounded-2xl border border-outline-variant/30">
                <p class="text-xs font-bold text-primary/60 uppercase tracking-wider mb-1">No. Pendaftaran</p>
                <p id="result-reg-number" class="font-bold text-on-surface text-base md:text-lg font-mono"></p>
              </div>
              <div class="md:col-span-2 bg-surface-container-low/50 p-4 rounded-2xl border border-outline-variant/30">
                <p class="text-xs font-bold text-primary/60 uppercase tracking-wider mb-2">Program & Jurusan</p>
                <p class="font-semibold text-on-surface flex items-center gap-2">
                  <span class="material-symbols-outlined text-primary text-lg">school</span>
                  <span id="result-program"></span>
                  <span id="result-major-wrapper" class="hidden text-on-surface-variant"> &mdash; <span id="result-major"></span></span>
                </p>
              </div>
            </div>

            <div class="flex flex-col sm:flex-row gap-3 w-full">
              <button id="btn-print" class="btn btn-primary sm:flex-1 !w-full flex items-center justify-center gap-2 py-3 cursor-pointer">
                <span class="material-symbols-outlined text-lg">print</span>
                Cetak Bukti Pendaftaran
              </button>
              <button id="btn-reset" class="btn btn-outline-primary sm:flex-1 !w-full flex items-center justify-center gap-2 py-3 cursor-pointer">
                <span class="material-symbols-outlined text-lg">refresh</span>
                Cek Data Lain
              </button>
            </div>
          </div>
        </div>

      </div>
    </Container>
  </section>
</MainLayout>

<script is:inline define:vars={{ cmsApiUrl: cmsUrl }}>
(function() {
  const form = document.getElementById('tracking-form');
  const errorBox = document.getElementById('tracking-error');
  const submitBtn = document.getElementById('tracking-submit');
  const submitText = document.getElementById('submit-text');
  const submitIcon = document.getElementById('submit-icon');
  const submitSpinner = document.getElementById('submit-spinner');
  const resultCard = document.getElementById('tracking-result');
  const btnReset = document.getElementById('btn-reset');
  const btnPrint = document.getElementById('btn-print');

  // Status mapping for colors and icons
  const statusTheme = {
    pending: { color: 'text-amber-600', bg: 'bg-amber-100', icon: 'hourglass_top' },
    verified: { color: 'text-blue-600', bg: 'bg-blue-100', icon: 'verified' },
    interview: { color: 'text-purple-600', bg: 'bg-purple-100', icon: 'groups' },
    accepted: { color: 'text-green-600', bg: 'bg-green-100', icon: 'check_circle' },
    rejected: { color: 'text-red-600', bg: 'bg-red-100', icon: 'cancel' },
    waitlisted: { color: 'text-slate-600', bg: 'bg-slate-100', icon: 'schedule' },
  };

  let currentLookupData = null;

  form?.addEventListener('submit', async function(e) {
    e.preventDefault();
    
    errorBox.classList.add('hidden');
    resultCard.classList.add('hidden');
    
    const regNumber = document.getElementById('regNumber').value.trim().toUpperCase();
    const birthDate = document.getElementById('birthDate').value.trim();

    if (!regNumber || !birthDate) {
      errorBox.textContent = 'Nomor pendaftaran dan tanggal lahir wajib diisi.';
      errorBox.classList.remove('hidden');
      return;
    }

    // Loading state
    submitBtn.disabled = true;
    submitText.textContent = 'Mencari...';
    submitIcon.classList.add('hidden');
    submitSpinner.classList.remove('hidden');

    const controller = new AbortController();
    const timeoutId = setTimeout(function() {
      controller.abort();
    }, 15000); // 15 seconds timeout

    try {
      const url = new URL('/api/admissions/registrations/lookup', window.location.origin);
      url.searchParams.set('number', regNumber);
      url.searchParams.set('birthDate', birthDate);

      const res = await fetch(url.toString(), {
        headers: { 'Accept': 'application/json' },
        signal: controller.signal
      });
      clearTimeout(timeoutId);

      const data = await res.json();

      if (res.ok) {
        currentLookupData = { regNumber, birthDate };
        
        // Populate result card
        const theme = statusTheme[data.status] || statusTheme.pending;
        
        const labelEl = document.getElementById('result-status-label');
        labelEl.textContent = data.statusLabel;
        labelEl.className = `text-2xl md:text-3xl font-bold tracking-tight mb-2 ${theme.color}`;
        
        const iconWrapper = document.getElementById('status-icon-wrapper');
        iconWrapper.className = `absolute top-0 right-8 -translate-y-1/2 w-16 h-16 rounded-full flex items-center justify-center border-4 border-white shadow-sm ${theme.bg}`;
        
        const iconEl = document.getElementById('status-icon');
        iconEl.textContent = theme.icon;
        iconEl.className = `material-symbols-outlined text-3xl ${theme.color}`;

        const noteEl = document.getElementById('result-admin-note');
        if (data.adminNote) {
          noteEl.innerHTML = `<span class="material-symbols-outlined text-base">info</span> <span>${data.adminNote}</span>`;
          noteEl.classList.remove('hidden');
        } else {
          noteEl.classList.add('hidden');
        }

        document.getElementById('result-name').textContent = data.fullName;
        document.getElementById('result-reg-number').textContent = data.registrationNumber;
        document.getElementById('result-program').textContent = data.program;
        
        const majorWrapper = document.getElementById('result-major-wrapper');
        if (data.major) {
          document.getElementById('result-major').textContent = data.major;
          majorWrapper.classList.remove('hidden');
        } else {
          majorWrapper.classList.add('hidden');
        }

        // Show print button only for accepted candidates
        if (data.status === 'accepted') {
          btnPrint?.classList.remove('hidden');
        } else {
          btnPrint?.classList.add('hidden');
        }

        // Show result, hide form
        form.classList.add('hidden');
        resultCard.classList.remove('hidden');
      } else {
        errorBox.textContent = data.error || 'Terjadi kesalahan. Silakan coba lagi.';
        errorBox.classList.remove('hidden');
      }
    } catch (err) {
      clearTimeout(timeoutId);
      if (err.name === 'AbortError') {
        errorBox.textContent = 'Koneksi ke server timeout (melebihi 15 detik). Silakan coba lagi.';
      } else {
        errorBox.textContent = 'Terjadi kesalahan koneksi jaringan.';
      }
      errorBox.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitText.textContent = 'Cari Data Pendaftaran';
      submitIcon.classList.remove('hidden');
      submitSpinner.classList.add('hidden');
    }
  });

  btnReset?.addEventListener('click', function() {
    form.reset();
    form.classList.remove('hidden');
    resultCard.classList.add('hidden');
    currentLookupData = null;
    document.getElementById('regNumber').focus();
  });

  btnPrint?.addEventListener('click', function() {
    if (currentLookupData) {
      window.open(`/pendaftaran/cetak?regNumber=${currentLookupData.regNumber}&birthDate=${currentLookupData.birthDate}`, '_blank');
    }
  });

  // Pre-fill from URL query param
  const urlParams = new URLSearchParams(window.location.search);
  const regParam = urlParams.get('reg');
  const birthParam = urlParams.get('birthDate');
  
  if (regParam) {
    const regInput = document.getElementById('regNumber');
    if (regInput) regInput.value = regParam.trim().toUpperCase();
  }
  if (birthParam) {
    const birthInput = document.getElementById('birthDate');
    if (birthInput) birthInput.value = birthParam.trim();
  }

  if (regParam && birthParam) {
    // If both parameters exist, auto-submit the form
    form.dispatchEvent(new Event('submit'));
  } else if (regParam) {
    // Focus on date of birth if registration number is prefilled
    document.getElementById('birthDate')?.focus();
  }
})();
</script>

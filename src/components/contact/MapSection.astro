---
interface Props {
  embedUrl?: string;
}

const { embedUrl = "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d126906.12642514332!2d106.71181824141675!3d-6.287870505187768!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2e69f106652136e9%3A0x66c891632f059c!2sJakarta%20Selatan%2C%20Kota%20Jakarta%20Selatan%2C%20Daerah%20Khusus%20Ibukota%20Jakarta!5e0!3m2!1sid!2sid!4v1714468000000!5m2!1sid!2sid" } = Astro.props;
---

<section class="h-[600px] w-full bg-outline-variant relative">
  <div class="absolute inset-0 bg-soft-primary-bg pointer-events-none z-10"></div>
  <iframe 
    src={embedUrl} 
    width="100%" 
    height="100%" 
    style="border:0;" 
    allowfullscreen="" 
    loading="lazy" 
    referrerpolicy="no-referrer-when-downgrade"
    class="grayscale contrast-125 brightness-110"
    title="Lokasi Sekolah"
  ></iframe>
</section>

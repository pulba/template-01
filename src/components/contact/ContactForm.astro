---
---

<form id="contact-form" class="space-y-4 bg-white p-6 lg:p-8 rounded-[1.125rem] shadow-sm border border-outline-variant">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div class="space-y-2">
      <label for="name" class="text-xs font-semibold text-primary uppercase tracking-widest ml-1">Nama Lengkap</label>
      <input 
        type="text" 
        id="name" 
        name="name" 
        required 
        placeholder="Masukkan nama Anda"
        class="w-full bg-white border border-outline-variant focus:border-primary/40 rounded-lg py-3 px-4 transition-all font-medium outline-none text-on-surface"
      />
    </div>
    <div class="space-y-2">
      <label for="email" class="text-xs font-semibold text-primary uppercase tracking-widest ml-1">Email</label>
      <input 
        type="email" 
        id="email" 
        name="email" 
        required 
        placeholder="nama@email.com"
        class="w-full bg-white border border-outline-variant focus:border-primary/40 rounded-lg py-3 px-4 transition-all font-medium outline-none text-on-surface"
      />
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div class="space-y-2">
      <label for="phone" class="text-xs font-semibold text-primary uppercase tracking-widest ml-1">No. Telepon (Opsional)</label>
      <input 
        type="tel" 
        id="phone" 
        name="phone" 
        placeholder="0812xxxx"
        class="w-full bg-white border border-outline-variant focus:border-primary/40 rounded-lg py-3 px-4 transition-all font-medium outline-none text-on-surface"
      />
    </div>
    <div class="space-y-2">
      <label for="subject" class="text-xs font-semibold text-primary uppercase tracking-widest ml-1">Subjek Pesan</label>
      <div class="relative">
        <select 
          id="subject" 
          name="subject" 
          required
          class="w-full bg-white border border-outline-variant focus:border-primary/40 rounded-lg py-3 px-4 transition-all font-medium outline-none appearance-none text-on-surface cursor-pointer"
        >
          <option value="" disabled selected>Pilih subjek</option>
          <option value="Informasi PPDB">Informasi PPDB</option>
          <option value="Kerjasama">Kerjasama</option>
          <option value="Kritik & Saran">Kritik & Saran</option>
          <option value="Lainnya">Lainnya</option>
        </select>
        <span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-primary opacity-40">expand_more</span>
      </div>
    </div>
  </div>

  <div class="space-y-2">
    <label for="message" class="text-xs font-semibold text-primary uppercase tracking-widest ml-1">Pesan Anda</label>
    <textarea 
      id="message" 
      name="message" 
      required 
      rows="5"
      placeholder="Tuliskan pesan Anda di sini..."
      class="w-full bg-white border border-outline-variant focus:border-primary/40 rounded-lg py-3 px-4 transition-all font-medium outline-none resize-none text-on-surface"
    ></textarea>
  </div>

  <button 
    type="submit" 
    class="w-full bg-primary text-white font-semibold py-4 rounded-full active:scale-[0.95] transition-all flex items-center justify-center gap-3 group"
  >
    <span>Kirim Pesan Sekarang</span>
    <span class="material-symbols-outlined group-hover:translate-x-2 transition-transform duration-300">send</span>
  </button>

  <!-- Status Messages -->
  <div id="form-status" class="hidden rounded-lg p-5 text-center font-bold animate-in fade-in slide-in-from-top-4"></div>
</form>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const statusDiv = document.getElementById('form-status');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!statusDiv) return;

    const formData = new FormData(form);
    statusDiv.classList.remove('hidden', 'bg-error-container', 'text-on-error-container', 'bg-surface-container-high text-primary', 'text-primary');
    statusDiv.classList.add('block', 'bg-soft-primary-bg', 'text-primary');
    statusDiv.textContent = 'Sedang mengirim pesan...';

    try {
      const response = await fetch('/api/contact', {
        method: 'POST',
        body: formData
      });

      const result = await response.json();

      statusDiv.classList.remove('bg-soft-primary-bg', 'text-primary');
      if (response.ok) {
        statusDiv.classList.add('bg-surface-container-high text-primary', 'text-primary');
        statusDiv.textContent = result.message;
        form.reset();
      } else {
        statusDiv.classList.add('bg-error-container', 'text-on-error-container');
        statusDiv.textContent = result.message;
      }
    } catch (error) {
      statusDiv.classList.remove('bg-soft-primary-bg', 'text-primary');
      statusDiv.classList.add('bg-error-container', 'text-on-error-container');
      statusDiv.textContent = 'Terjadi kesalahan koneksi. Silakan coba lagi nanti.';
    }
    
    // Hide status after 5 seconds if success
    if (statusDiv.classList.contains('text-primary')) {
      setTimeout(() => {
        statusDiv.classList.add('hidden');
      }, 5000);
    }
  });
</script>

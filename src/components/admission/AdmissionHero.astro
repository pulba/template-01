---
import Container from '@/components/ui/Container.astro';

interface Props {
  title: string;
  subtitle: string;
}

const { title, subtitle } = Astro.props;
---

<section class="bg-primary py-20 md:py-28 relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-primary via-primary to-primary-fixed/90 z-10"></div>
  
  <Container class="relative z-20 text-center">
    <span class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-md border border-white/20 rounded-full px-5 py-2 text-white/90 text-sm font-medium mb-8">
      <span class="material-symbols-outlined text-lg">school</span>
      Penerimaan Peserta Didik Baru
    </span>
    <h1 class="text-2xl md:text-3xl font-bold text-white mb-6 drop-shadow-md">{title}</h1>
    <p class="font-body-lg text-primary-fixed opacity-80 max-w-2xl mx-auto leading-relaxed">
      {subtitle}
    </p>
    <div class="w-16 h-1 bg-secondary-container mx-auto mt-10 rounded-full"></div>
  </Container>
</section>

---
import Container from "@/components/ui/Container.astro";

interface Props {
  title: string;
  tagline?: string;
  isReversed?: boolean;
  image?: string;
  bgVariant?: "white" | "low";
}

const { title, tagline, isReversed, image, bgVariant = "white" } = Astro.props;
---

<section
  class={`py-16 ${bgVariant === "low" ? "bg-surface-container-low" : "bg-surface-container-lowest"}`}
>
  <Container>
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-center">
      <!-- Image Side -->
      {
        image && (
          <div class={`lg:col-span-5 ${isReversed ? 'lg:order-first' : 'lg:order-last'}`}>
            <div class="rounded-[1.125rem] overflow-hidden shadow-sm bg-gray-100 aspect-square">
              <img src={image} alt={title} class="w-full h-full object-cover" />
            </div>
          </div>
        )
      }

      <!-- Text Side -->
      <div class={`lg:col-span-7 flex flex-col ${isReversed ? 'lg:order-last' : 'lg:order-first'}`}>
        {
          tagline && (
            <span class="text-secondary-container font-bold uppercase tracking-widest text-sm mb-4 block">
              {tagline}
            </span>
          )
        }
        <h2 class="font-h1 text-primary mb-6">{title}</h2>
        <div class="prose prose-base md:prose-lg max-w-[65ch] text-on-surface-variant space-y-5 leading-loose">
          <slot />
        </div>
      </div>
    </div>
  </Container>
</section>

---
import Container from '@/components/ui/Container.astro';
import Icon from '@/components/ui/Icon.astro';

interface Props {
  name: string;
  signature: string;
  message: string[];
  image: string;
  quote?: string;
}

const { name, signature, message, image, quote } = Astro.props;
---

<section class="py-16 bg-surface-container-lowest relative overflow-hidden">
  <Container>
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-start">
      <!-- Image & Name Side -->
      <div class="lg:col-span-5 lg:sticky lg:top-32">
        <div class="relative group">
          <div class="relative rounded-[1.125rem] overflow-hidden shadow-sm aspect-[4/5] bg-gray-100">
            <img src={image} alt={name} class="w-full h-full object-cover" />
          </div>
        </div>
        <div class="mt-6 text-center lg:text-left">
          <h3 class="font-h2 text-primary text-2xl lg:text-3xl">{name}</h3>
          <p class="text-on-surface-variant font-medium text-lg mt-1">{signature}</p>
        </div>
      </div>
      
      <!-- Message Side -->
      <div class="lg:col-span-7">
        <div class="flex flex-col gap-6">
          <span class="inline-flex bg-soft-primary-bg text-primary px-5 py-2 rounded-full text-sm font-bold uppercase tracking-widest w-fit">
            Sambutan Utama
          </span>
          <h2 class="font-h1 text-primary leading-tight">Mewujudkan Generasi Unggul Berkarakter & Berwawasan Global</h2>
        </div>
        
        <div class="mt-8 space-y-4 font-body-lg text-on-surface-variant leading-relaxed">
          {message.map(p => <p>{p}</p>)}
        </div>

        {quote && (
          <div class="mt-8 bg-background p-6 rounded-[1.125rem] border-l-4 border-primary relative overflow-hidden">
            <Icon name="format_quote" size="xl" class="text-border-soft absolute top-4 right-4 group-hover:scale-125 transition-all duration-500" />
            <p class="italic text-2xl font-semibold text-primary relative z-10 leading-relaxed font-inter">
              "{quote}"
            </p>
          </div>
        )}
      </div>
    </div>
  </Container>
</section>

---
import GalleryItem from '@/components/home/GalleryItem.astro';
import type { GalleryImage } from '@/types/homepage';

interface Props {
  images: GalleryImage[];
}

const { images } = Astro.props;
---

<div id="gallery-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4 md:gap-6 transition-all duration-300">
  {images.map((img, i) => (
    <GalleryItem {...img} category={img.category} loading={i < 4 ? "eager" : "lazy"} />
  ))}
</div>

<div id="gallery-empty-state" class="hidden py-16 text-center text-on-surface-variant flex-col items-center justify-center">
  <div class="mb-4 text-outline/50">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
    </svg>
  </div>
  <p class="text-lg font-medium">Belum ada foto pada kategori ini.</p>
  <p class="text-sm mt-1">Silakan pilih kategori lain.</p>
</div>

---
import Container from "@/components/ui/Container.astro";
import Icon from "@/components/ui/Icon.astro";

interface Props {
  title: string;
  subtitle: string;
}

const { title, subtitle } = Astro.props;
---

<section class="bg-primary py-10 md:py-20 relative overflow-hidden">
  <!-- Subtle gradient instead of patterns -->
  <div
    class="absolute inset-0 bg-gradient-to-br from-primary via-primary-dark to-primary opacity-60"
  >
  </div>

  <div
    class="absolute -right-24 -top-24 w-96 h-96 bg-surface-container-lowest/5 rounded-full blur-3xl"
  >
  </div>

  <Container class="relative z-20">
    <div class="max-w-2xl">
      <div class="flex items-center gap-3 text-secondary-container mb-3 md:mb-6">
        <Icon name="photo_library" size="sm" />
        <span class="font-bold uppercase tracking-widest text-sm"
          >Visual Archive</span
        >
      </div>
      <h1 class="text-2xl md:text-3xl font-bold text-white mb-3 md:mb-6 drop-shadow-md">{title}</h1>
      <p class="text-primary-fixed opacity-80 leading-relaxed">
        {subtitle}
      </p>
    </div>
  </Container>
</section>

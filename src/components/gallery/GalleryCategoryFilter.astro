---
const categories = ["Semua", "Akademik", "Olahraga", "Kesenian", "Fasilitas"];
---

<div class="mb-6 md:mb-10">
  <!-- Desktop: centered wrap -->
  <div class="hidden md:flex md:flex-wrap md:justify-center gap-3">
    {
      categories.map((cat, i) => (
        <button
          data-filter={cat.toLowerCase()}
          class={`filter-btn px-6 py-2 rounded-full font-semibold transition-all border text-sm uppercase tracking-wider ${
            i === 0
              ? "bg-primary text-white border-primary"
              : "bg-white text-on-surface-variant border-outline-variant hover:border-primary/30"
          }`}
        >
          {cat}
        </button>
      ))
    }
  </div>

  <!-- Mobile: horizontal scroll with arrow buttons -->
  <div class="md:hidden relative px-2">
    <!-- Left Arrow -->
    <button
      id="filter-scroll-left"
      type="button"
      aria-label="Geser filter ke kiri"
      class="absolute left-0 top-1/2 -translate-y-1/2 z-10 w-7 h-7 rounded-full bg-white shadow-md flex items-center justify-center text-primary opacity-0 transition-opacity duration-200 pointer-events-none"
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
    </button>

    <!-- Scrollable Filter Area -->
    <div
      id="filter-scroll-container"
      class="flex gap-2 overflow-x-scroll pl-8 pr-8 pb-3"
      style="scroll-behavior: smooth; -webkit-overflow-scrolling: touch; scrollbar-width: none;"
    >
      <style>
        #filter-scroll-container::-webkit-scrollbar { display: none; }
      </style>
      {
        categories.map((cat, i) => (
          <button
            data-filter={cat.toLowerCase()}
            class={`filter-btn px-5 py-2 rounded-full font-semibold transition-all border text-xs uppercase tracking-wider whitespace-nowrap flex-shrink-0 ${
              i === 0
                ? "bg-primary text-white border-primary"
                : "bg-white text-on-surface-variant border-outline-variant hover:border-primary/30"
            }`}
          >
            {cat}
          </button>
        ))
      }
    </div>

    <!-- Right Arrow -->
    <button
      id="filter-scroll-right"
      type="button"
      aria-label="Geser filter ke kanan"
      class="absolute right-0 top-1/2 -translate-y-1/2 z-10 w-7 h-7 rounded-full bg-white shadow-md flex items-center justify-center text-primary transition-opacity duration-200"
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
    </button>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const container = document.getElementById('filter-scroll-container');
    const leftBtn = document.getElementById('filter-scroll-left');
    const rightBtn = document.getElementById('filter-scroll-right');

    if (!container || !leftBtn || !rightBtn) return;

    const SCROLL_AMOUNT = 120;

    function updateArrows() {
      const { scrollLeft, scrollWidth, clientWidth } = container!;
      const maxScroll = scrollWidth - clientWidth;

      // Show/hide left arrow
      if (scrollLeft > 5) {
        leftBtn!.classList.remove('opacity-0', 'pointer-events-none');
        leftBtn!.classList.add('opacity-100', 'pointer-events-auto');
      } else {
        leftBtn!.classList.add('opacity-0', 'pointer-events-none');
        leftBtn!.classList.remove('opacity-100', 'pointer-events-auto');
      }

      // Show/hide right arrow
      if (scrollLeft < maxScroll - 5) {
        rightBtn!.classList.remove('opacity-0', 'pointer-events-none');
        rightBtn!.classList.add('opacity-100', 'pointer-events-auto');
      } else {
        rightBtn!.classList.add('opacity-0', 'pointer-events-none');
        rightBtn!.classList.remove('opacity-100', 'pointer-events-auto');
      }
    }

    leftBtn.addEventListener('click', () => {
      container!.scrollBy({ left: -SCROLL_AMOUNT, behavior: 'smooth' });
    });

    rightBtn.addEventListener('click', () => {
      container!.scrollBy({ left: SCROLL_AMOUNT, behavior: 'smooth' });
    });

    container.addEventListener('scroll', updateArrows, { passive: true });

    // Initial check
    updateArrows();
  });
</script>

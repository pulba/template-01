---
import Container from '@/components/ui/Container.astro';

interface Props {
  title: string;
  subtitle: string;
}

const { title, subtitle } = Astro.props;

const term = Astro.locals.terminology?.dictionary;
---

<section class="bg-surface-container-high py-24 border-b border-outline-variant relative overflow-hidden">
  <div class="absolute top-0 right-0 w-64 h-64 bg-soft-primary-bg rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>
  <div class="absolute bottom-0 left-0 w-64 h-64 bg-soft-accent-bg rounded-full blur-3xl translate-y-1/2 -translate-x-1/2"></div>

  <Container class="relative z-10 text-center">
    <span class="text-primary font-bold uppercase tracking-widest text-sm mb-4 block">
      {term?.teacher?.label || 'Guru'} & {term?.staff?.label || 'Staff'}
    </span>
    <h1 class="text-2xl md:text-3xl font-bold text-primary mb-6">{title}</h1>
    <p class="font-body-lg text-on-surface-variant max-w-2xl mx-auto leading-relaxed">
      {subtitle}
    </p>
    <div class="w-16 h-1 bg-secondary-container mx-auto mt-8 rounded-full"></div>
  </Container>
</section>

---
import Container from '@/components/ui/Container.astro';
import Icon from '@/components/ui/Icon.astro';

interface Props {
  title: string;
  subtitle: string;
}

const { title, subtitle } = Astro.props;
---

<section class="bg-primary pt-32 pb-20 relative overflow-hidden">
  <!-- Decorative Elements -->
  <div class="absolute -top-24 -right-24 w-96 h-96 bg-surface-container-lowest/5 rounded-full blur-3xl"></div>
  <div class="absolute -bottom-24 -left-24 w-64 h-64 bg-soft-accent-bg rounded-full blur-2xl"></div>

  <Container class="relative z-10 text-center">
    <div class="inline-flex items-center gap-3 bg-surface-container-lowest/10 text-primary-fixed px-6 py-2 rounded-full mb-8 backdrop-blur-md border border-surface-container-lowest/10">
      <Icon name="event" size="sm" />
      <span class="text-sm font-bold uppercase tracking-widest">School Calendar</span>
    </div>
    <h1 class="text-2xl md:text-3xl font-bold text-white mb-6 drop-shadow-lg">{title}</h1>
    <p class="font-body-lg text-primary-fixed opacity-80 max-w-2xl mx-auto leading-relaxed">
      {subtitle}
    </p>
  </Container>
</section>

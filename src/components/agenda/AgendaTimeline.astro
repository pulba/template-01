---
import AgendaItem from '@/components/home/AgendaItem.astro';
import type { AgendaItemData } from '@/types/homepage';

interface Props {
  agendas: AgendaItemData[];
}

const { agendas } = Astro.props;
---

<div class="space-y-6">
  {agendas.map(agenda => (
    <div class="bg-surface-container-lowest p-2 rounded-lg shadow-sm hover:shadow-xl transition-all border border-outline-variant group">
      <AgendaItem {...agenda} variant="light" />
    </div>
  ))}
</div>

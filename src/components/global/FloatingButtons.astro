---
import Icon from "@/components/ui/Icon.astro";

const term = Astro.locals.terminology?.dictionary;
const admissionsLabel = term?.admissions?.short || "PPDB";
---

<div class="fixed bottom-8 right-8 z-[100] flex flex-col gap-4">
  <!-- Admissions CTA -->
  <a
    href="/pendaftaran"
    class="bg-[#00a859] text-white px-6 py-3 rounded-full flex items-center gap-3 shadow-lg hover:scale-105 active:scale-95 transition-all duration-200 group"
    aria-label={`Daftar ${admissionsLabel}`}
  >
    <Icon name="school" size="sm" />
    <span class="text-sm font-bold whitespace-nowrap">
      Daftar {admissionsLabel}
    </span>
  </a>
</div>

---
import Icon from "@/components/ui/Icon.astro";
import { Image } from "astro:assets";

interface Props {
  id: number;
  name: string;
  position: string | null;
  photo: string | null;
  description: string | null;
}

const { name, position, photo, description } = Astro.props;
const displayImage = photo || '/images/placeholders/user.webp';
---

<div class="bg-surface-container-lowest rounded-lg p-6 shadow-sm hover:shadow-xl transition-all duration-500 border border-outline-variant group flex flex-col h-full">
  <!-- Image Wrapper -->
  <div class="relative aspect-[3/4] rounded-lg overflow-hidden mb-6 bg-surface-container-highest">
    <Image
      src={displayImage}
      alt={name}
      width={400}
      height={533}
      class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700 group-hover:scale-110"
      loading="lazy"
      decoding="async"
    />
    <!-- Hover Overlay -->
    <div class="absolute inset-0 bg-gradient-to-t from-primary/90 via-primary/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-end p-8">
      <div class="text-white transform translate-y-6 group-hover:translate-y-0 transition-transform duration-500">
        <p class="text-sm font-medium line-clamp-3 italic leading-relaxed opacity-90">
          "{description || "Berdedikasi untuk memajukan kegiatan kesiswaan dan membangun karakter positif di lingkungan sekolah."}"
        </p>
      </div>
    </div>
  </div>

  <!-- Info -->
  <div class="text-center mt-auto">
    <h3 class="font-h3 text-primary group-hover:text-hover-heading-safe transition-colors mb-1">
      {name}
    </h3>
    
    {position && (
      <div class="inline-flex items-center gap-2 bg-soft-primary-bg text-primary px-4 py-2 rounded-lg text-xs font-bold border border-border-soft mt-3">
        <Icon name="verified_user" size="sm" />
        {position}
      </div>
    )}
  </div>
</div>

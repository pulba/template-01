---
import Icon from "@/components/ui/Icon.astro";

interface Props {
  title: string;
  subtitle?: string;
  viewAllLink?: string;
  viewAllText?: string;
  class?: string;
  dark?: boolean;
}

const {
  title,
  subtitle,
  viewAllLink,
  viewAllText = "Lihat Semua",
  class: className,
  dark = false,
} = Astro.props;
---

<div
  class:list={[
    "flex flex-col sm:flex-row sm:justify-between sm:items-end gap-4 mb-8",
    className,
  ]}
>
  <div class="max-w-2xl">
    <h2 class:list={["font-h2 leading-tight", dark ? "text-primary-fixed" : "text-primary"]}>
      {title}
    </h2>
    {subtitle && (
      <p class:list={["mt-2 text-sm md:text-base", dark ? "text-white/80" : "text-on-surface-variant"]}>
        {subtitle}
      </p>
    )}
  </div>
  {
    viewAllLink && (
      <a
        href={viewAllLink}
        class:list={[
          "inline-flex items-center gap-1.5 font-semibold hover:opacity-80 transition-opacity text-sm shrink-0",
          dark ? "text-white" : "text-primary",
        ]}
      >
        {viewAllText} <Icon name="arrow_forward" size="sm" />
      </a>
    )
  }
</div>

---
interface Props {
  currentPage: number;
  totalPages: number;
  baseUrl: string;
}

const { currentPage, totalPages, baseUrl } = Astro.props;

// Generate page numbers
const getPageNumbers = () => {
  const pages: (number | string)[] = [];
  
  if (totalPages <= 5) {
    for (let i = 1; i <= totalPages; i++) {
      pages.push(i);
    }
  } else {
    // Always show first, last, and pages around current
    if (currentPage <= 3) {
      pages.push(1, 2, 3, 4, '...', totalPages);
    } else if (currentPage >= totalPages - 2) {
      pages.push(1, '...', totalPages - 3, totalPages - 2, totalPages - 1, totalPages);
    } else {
      pages.push(1, '...', currentPage - 1, currentPage, currentPage + 1, '...', totalPages);
    }
  }
  
  return pages;
};

const pages = getPageNumbers();
const prevUrl = currentPage > 1 ? `${baseUrl}?page=${currentPage - 1}` : null;
const nextUrl = currentPage < totalPages ? `${baseUrl}?page=${currentPage + 1}` : null;
---

{totalPages > 1 && (
  <nav class="flex justify-center items-center gap-2 mt-12" aria-label="Pagination">
    {prevUrl ? (
      <a 
        href={prevUrl} 
        class="pagination-link w-10 h-10 flex items-center justify-center rounded-full bg-surface border border-outline-variant text-on-surface hover:text-primary hover:border-primary transition-colors duration-200 shadow-sm"
        aria-label="Previous page"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      </a>
    ) : (
      <span class="w-10 h-10 flex items-center justify-center rounded-full bg-surface border border-outline-variant text-on-surface/30 cursor-not-allowed">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      </span>
    )}

    <ul class="flex items-center gap-1">
      {pages.map(page => (
        <li>
          {page === '...' ? (
            <span class="w-10 h-10 flex items-center justify-center text-on-surface-variant font-medium">...</span>
          ) : (
            <a 
              href={`${baseUrl}?page=${page}`}
              class:list={[
                "pagination-link w-10 h-10 flex items-center justify-center rounded-full font-medium transition-colors duration-200 shadow-sm",
                currentPage === page 
                  ? "bg-primary text-on-primary shadow-md" 
                  : "bg-surface border border-outline-variant text-on-surface hover:text-primary hover:border-primary"
              ]}
              aria-current={currentPage === page ? "page" : undefined}
            >
              {page}
            </a>
          )}
        </li>
      ))}
    </ul>

    {nextUrl ? (
      <a 
        href={nextUrl} 
        class="pagination-link w-10 h-10 flex items-center justify-center rounded-full bg-surface border border-outline-variant text-on-surface hover:text-primary hover:border-primary transition-colors duration-200 shadow-sm"
        aria-label="Next page"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      </a>
    ) : (
      <span class="w-10 h-10 flex items-center justify-center rounded-full bg-surface border border-outline-variant text-on-surface/30 cursor-not-allowed">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      </span>
    )}
  </nav>
)}

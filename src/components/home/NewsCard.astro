---
import Icon from "@/components/ui/Icon.astro";
import Badge from "@/components/ui/Badge.astro";
import { Image } from "astro:assets";

interface Props {
  image: string;
  category: string;
  date: string;
  title: string;
  excerpt: string;
  href: string;
}

const { image, category, date, title, excerpt, href } = Astro.props;
const hasImage = image && image.trim() !== "";

const categoryHref = `/berita?kategori=${category.toLowerCase()}`;
---

<article class="card group h-full">
  <!-- Image Container -->
  <a href={href} class="aspect-video relative overflow-hidden block">
    {
      hasImage ? (
        <Image
          src={image}
          alt={title}
          width={600}
          height={400}
          class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.02]"
          loading="lazy"
          decoding="async"
        />
      ) : (
        <div class="w-full h-full bg-gradient-to-br from-gray-50 to-gray-100 flex items-center justify-center">
          <Icon name="image" size="lg" class="text-outline-variant" />
        </div>
      )
    }
  </a>

  <!-- Content -->
  <div class="p-6 flex-grow flex flex-col">
    <div class="flex items-center gap-3 mb-4">
      <a href={categoryHref} class="hover:opacity-80 transition-opacity relative z-10">
        <Badge
          variant={category === "PRESTASI"
            ? "primary"
            : category === "AKADEMIK"
              ? "secondary"
              : category === "EKSKUL"
                ? "tertiary"
                : "neutral"}
          rounded="md"
          class="!text-white"
        >
          {category}
        </Badge>
      </a>
      <span class="text-outline text-xs font-medium">{date}</span>
    </div>

    <a href={href} class="block mb-3">
      <h3
        class="font-h3 text-on-surface leading-tight group-hover:text-primary transition-colors line-clamp-2"
      >
        {title}
      </h3>
    </a>
    
    <p class="font-body-md text-on-surface-variant line-clamp-3 mb-6">
      {excerpt}
    </p>

    <div class="mt-auto">
      <a
        href={href}
        class="text-primary font-bold text-xs flex items-center gap-2 hover:opacity-70 transition-opacity"
      >
        Baca Selengkapnya
        <Icon
          name="arrow_forward"
          size="xs"
          class="group-hover:translate-x-1 transition-transform"
        />
      </a>
    </div>
  </div>
</article>

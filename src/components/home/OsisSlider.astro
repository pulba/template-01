---
import Container from "@/components/ui/Container.astro";
import SectionHeader from "@/components/ui/SectionHeader.astro";
import { Image } from "astro:assets";
import type { OsisMember } from "@/types/homepage";

interface Props {
  osisItems: OsisMember[];
}

import "swiper/css";
import "swiper/css/navigation";
import "swiper/css/pagination";

const { osisItems } = Astro.props;
const term = Astro.locals.terminology?.dictionary;
---

<section class="section-padding bg-surface">
  <Container>
    <SectionHeader
      title="Pengurus OSIS"
      subtitle={`Mengenal para pemimpin masa depan penggerak kegiatan ${term?.student?.label?.toLowerCase() || "siswa"}.`}
      viewAllLink="/osis"
      viewAllText="Semua Pengurus"
    />

    <div class="relative px-2 md:px-12 mt-10">
      <div class="swiper osis-swiper w-full">
        <div class="swiper-wrapper py-4">
          {
            osisItems.map((member) => (
              <div class="swiper-slide !h-auto">
                <div class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-300 h-full flex flex-col border border-outline-variant relative">
                  <div class="relative w-full aspect-[4/5] bg-surface-container-highest overflow-hidden">
                    {member.photo ? (
                      <img
                        src={member.photo}
                        alt={member.name}
                        class="w-full h-full object-cover object-top hover:scale-105 transition-transform duration-500"
                        loading="lazy"
                      />
                    ) : (
                      <div class="w-full h-full flex items-center justify-center text-on-surface-variant">
                        <span class="text-4xl">🧑‍🎓</span>
                      </div>
                    )}
                  </div>
                  <div class="p-5 flex flex-col flex-grow text-center items-center bg-surface-variant border-t border-outline-variant">
                    <h3 class="text-lg font-bold text-on-surface font-inter leading-tight mb-auto">
                      {member.name}
                    </h3>
                    <div class="inline-flex items-center justify-center bg-primary text-on-primary px-3 py-1.5 mt-3 rounded-md text-xs font-bold shadow-sm w-full uppercase tracking-wider">
                      {member.position}
                    </div>
                  </div>
                </div>
              </div>
            ))
          }
        </div>

        <!-- Pagination -->
        <div class="swiper-pagination !-bottom-2 md:!-bottom-6"></div>
      </div>

      <!-- Custom Navigation -->
      <button
        class="osis-swiper-prev absolute top-1/2 -translate-y-1/2 left-0 z-10 w-10 h-10 flex items-center justify-center bg-surface shadow-md border border-outline-variant rounded-full text-on-surface hover:text-primary hover:border-primary disabled:opacity-50 disabled:cursor-not-allowed transition-all hidden md:flex"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"><path d="m15 18-6-6 6-6"></path></svg
        >
      </button>
      <button
        class="osis-swiper-next absolute top-1/2 -translate-y-1/2 right-0 z-10 w-10 h-10 flex items-center justify-center bg-surface shadow-md border border-outline-variant rounded-full text-on-surface hover:text-primary hover:border-primary disabled:opacity-50 disabled:cursor-not-allowed transition-all hidden md:flex"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"><path d="m9 18 6-6-6-6"></path></svg
        >
      </button>
    </div>
  </Container>
</section>

<script>
  import Swiper from "swiper";
  import { Navigation, Pagination, Autoplay } from "swiper/modules";

  function initOsisSlider() {
    new Swiper(".osis-swiper", {
      modules: [Navigation, Pagination, Autoplay],
      slidesPerView: 1,
      spaceBetween: 24,
      loop: true,
      autoplay: {
        delay: 4500,
        disableOnInteraction: false,
      },
      pagination: {
        el: ".osis-swiper .swiper-pagination",
        clickable: true,
        dynamicBullets: true,
      },
      navigation: {
        nextEl: ".osis-swiper-next",
        prevEl: ".osis-swiper-prev",
      },
      breakpoints: {
        640: {
          slidesPerView: 2,
        },
        768: {
          slidesPerView: 3,
        },
        1024: {
          slidesPerView: 4,
        },
        1280: {
          slidesPerView: 5,
        },
      },
    });
  }

  // Run on first load
  initOsisSlider();
</script>

<style is:global>
  .osis-swiper {
    padding-bottom: 3rem !important;
  }
  .osis-swiper .swiper-pagination-bullet {
    background: var(--theme-primary, #00288e);
  }
</style>

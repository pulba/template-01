---
import Container from "@/components/ui/Container.astro";
import Icon from "@/components/ui/Icon.astro";
import Button from "@/components/ui/Button.astro";
import { Image } from "astro:assets";

interface Props {
  tagline?: string;
  headline: string;
  principalName: string;
  signatureLabel: string;
  message: string[];
  quote?: string;
  image: string;
}

const {
  tagline = "Sambutan Kami",
  headline,
  principalName,
  signatureLabel,
  message,
  quote,
  image,
} = Astro.props;

// Create excerpt from message
const fullMessage = message.join(' ');
const excerpt = fullMessage.length > 350 ? fullMessage.substring(0, 350) + '...' : fullMessage;

// Fetch school name from Astro.locals to avoid duplicates and create a clean fallback headline
const schoolName = Astro.locals.schoolProfile?.schoolName || 'SMA Negeri 1 Nusantara';
const displayHeadline = (headline === principalName)
  ? `Sambutan Kepala Madrasah`
  : headline;
---

<section class="section-padding overflow-hidden bg-white">
  <Container>
    <div
      class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-20 items-center"
    >
      <!-- Portrait Column -->
      <div class="lg:col-span-4 relative group">
        <!-- Main Portrait -->
        <div
          class="relative rounded-[2.5rem] overflow-hidden shadow-2xl aspect-[4/5] bg-surface-container"
        >
          <Image
            src={image}
            alt={principalName}
            width={800}
            height={1000}
            class="w-full h-full object-cover"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>

      <!-- Content Column -->
      <div class="lg:col-span-8">
        <div class="mb-8">
          <h2 class="text-2xl lg:text-3xl font-bold text-primary mb-4 leading-tight">
            {displayHeadline}
          </h2>
          <div class="w-16 h-1.5 bg-primary"></div>
        </div>

        <div
          class="text-on-surface-variant font-body-lg leading-relaxed mb-8"
        >
          <p class="text-base lg:text-lg">
            {excerpt}
          </p>
        </div>

        <div class="mb-10">
          <Button
            href="/profil"
            class="inline-flex items-center gap-2 uppercase tracking-widest group !w-auto !text-xs !py-2 !px-6"
          >
            SELENGKAPNYA
            <Icon
              name="arrow_forward"
              size="xs"
              class="group-hover:translate-x-1 transition-transform"
            />
          </Button>
        </div>

        <div class="pt-8 border-t border-outline-variant/30">
          <div class="font-bold text-2xl text-primary">{principalName}</div>
          <div class="text-on-surface-variant font-medium mt-1">{signatureLabel}</div>
        </div>
      </div>
    </div>
  </Container>
</section>

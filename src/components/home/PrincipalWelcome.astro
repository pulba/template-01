---
import Container from "@/components/ui/Container.astro";
import Icon from "@/components/ui/Icon.astro";
import Button from "@/components/ui/Button.astro";
import { Image } from "astro:assets";

interface Props {
  tagline?: string;
  headline: string;
  principalName: string;
  signatureLabel: string;
  message: string[];
  quote?: string;
  image: string;
}

const {
  tagline = "Sambutan Kami",
  headline,
  principalName,
  signatureLabel,
  message,
  quote,
  image,
} = Astro.props;

// Fetch school name from Astro.locals to avoid duplicates and create a clean fallback headline
const schoolName = Astro.locals.schoolProfile?.schoolName || 'SMA Negeri 1 Nusantara';
const displayHeadline = (headline === principalName)
  ? `Selamat Datang di ${schoolName}`
  : headline;
---

<section class="section-padding overflow-hidden">
  <Container>
    <div
      class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-center"
    >
      <!-- Portrait Column -->
      <div class="lg:col-span-5 relative group">
        <!-- Decorative Background Gradients & Outlines -->
        <div class="absolute -inset-6 bg-gradient-to-tr from-primary/10 to-secondary-container/10 rounded-[2.5rem] blur-2xl -z-20 opacity-80 group-hover:scale-105 transition-transform duration-700"></div>
        <div class="absolute inset-0 border border-primary/20 rounded-[1.5rem] translate-x-4 translate-y-4 -z-10 group-hover:translate-x-2 group-hover:translate-y-2 transition-transform duration-500"></div>

        <!-- Main Portrait -->
        <div
          class="relative rounded-[1.5rem] overflow-hidden shadow-product aspect-[4/5] bg-surface-container border border-outline-variant/40 transform group-hover:-translate-y-1 group-hover:scale-[1.01] transition-all duration-500"
        >
          <Image
            src={image}
            alt={principalName}
            width={800}
            height={1000}
            class="w-full h-full object-cover"
            loading="lazy"
            decoding="async"
          />
          <!-- Dark overlay at the bottom to blend the floating card -->
          <div class="absolute inset-0 bg-gradient-to-t from-primary/20 to-transparent opacity-60"></div>
        </div>

        <!-- Floating Principal ID Card -->
        <div
          class="absolute -bottom-6 -right-4 bg-surface-container-lowest border border-outline-variant shadow-xl p-5 rounded-2xl min-w-[250px] transform group-hover:translate-y-[-4px] transition-all duration-500"
        >
          <div class="flex items-center gap-3">
            <div class="w-1 h-10 bg-primary rounded-full"></div>
            <div>
              <div class="font-h3 text-primary leading-tight font-bold">{principalName}</div>
              <div class="text-muted-text text-xs mt-1 font-semibold tracking-wide uppercase">{signatureLabel}</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Content Column -->
      <div class="lg:col-span-7 mt-8 lg:mt-0">
        <!-- Tagline Indicator Badge -->
        <div class="inline-flex items-center gap-2 bg-primary/5 border border-primary/10 text-primary px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-widest mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse"></span>
          {tagline}
        </div>

        <h2 class="font-display-lg text-primary mb-6 leading-tight">
          {displayHeadline}
        </h2>

        <div
          class="space-y-4 text-on-surface-variant font-body-lg leading-relaxed"
        >
          {message.slice(0, 2).map((paragraph, index) => (
            <p class={index === 0 ? "font-semibold text-primary/90 text-lg mb-2" : ""}>
              {paragraph}
            </p>
          ))}
        </div>

        <div class="mt-8 flex flex-wrap items-center gap-4">
          <Button
            href="/profil"
            variant="outline-primary"
            class="inline-flex items-center gap-2 group shadow-sm rounded-full"
          >
            Baca Selengkapnya
            <Icon
              name="arrow_forward"
              size="sm"
              class="group-hover:translate-x-1 transition-transform"
            />
          </Button>
        </div>

        {
          quote && (
            <div class="mt-8 relative p-6 bg-surface-container-low border border-outline-variant/60 rounded-2xl overflow-hidden group/quote">
              <!-- Watermark Background Quote Icon -->
              <div class="absolute -right-4 -bottom-6 text-primary/5 select-none pointer-events-none transform -rotate-12">
                <Icon name="format_quote" size="xl" class="w-24 h-24" />
              </div>
              <div class="flex gap-4">
                <div class="text-primary shrink-0 mt-0.5">
                  <Icon name="format_quote" size="lg" />
                </div>
                <p class="italic font-medium text-primary text-base md:text-lg leading-relaxed relative z-10">
                  "{quote}"
                </p>
              </div>
            </div>
          )
        }
      </div>
    </div>
  </Container>
</section>

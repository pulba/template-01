---
import Icon from '@/components/ui/Icon.astro';
import { Image } from 'astro:assets';

interface Props {
  image: string;
  alt: string;
  span?: 'large' | 'small';
  loading?: 'lazy' | 'eager';
  category?: string;
}

const { image, alt, loading = 'lazy', category = 'Umum' } = Astro.props;
---

<a 
  href={image} 
  rel="noopener noreferrer" 
  data-category={category.toLowerCase()}
  class="gallery-item block relative group overflow-hidden rounded-2xl cursor-pointer bg-surface-container-highest focus:outline-none focus-visible:ring-2 focus-visible:ring-primary/50 gallery-card aspect-[4/3]"
>
  <div class="w-full h-full flex flex-col items-center justify-center overflow-hidden">
    {image ? (
        <Image 
        src={image} 
        alt={alt}
        width={600}
        height={600}
        class="w-full h-full object-cover gallery-image group-hover:scale-[1.04]"
        loading={loading}
        decoding="async"
      />
    ) : (
      <div class="p-6 text-center text-on-surface-variant opacity-40">
        <Icon name="image_not_supported" size="xl" />
        <p class="text-xs mt-2 font-medium">{alt}</p>
      </div>
    )}
    
    <!-- Fallback alt text in case Image fails but isn't empty -->
    <div class="absolute inset-0 flex items-center justify-center p-4 text-center pointer-events-none opacity-0 group-hover:opacity-10 transition-opacity">
       <span class="text-[10px] font-medium text-black uppercase tracking-tight">{alt}</span>
    </div>
  </div>
  
  <!-- Permanent Bottom Gradient Overlay with Title -->
  <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent p-5 pt-12 pointer-events-none">
    <span class="text-[10px] font-bold text-primary-fixed-dim uppercase tracking-wider block mb-1">{category}</span>
    <h3 class="text-sm font-bold text-white leading-tight line-clamp-2 text-shadow-sm">{alt}</h3>
  </div>

  <!-- Hover Overlay for Centered Zoom Icon -->
  <div class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 hover-overlay flex items-center justify-center pointer-events-none">
    <div class="w-12 h-12 rounded-full bg-white/95 text-primary flex items-center justify-center transform scale-75 group-hover:scale-100 zoom-icon shadow-xl backdrop-blur-md">
      <Icon name="zoom_in" size="lg" class="text-primary" />
    </div>
  </div>
</a>

<style>
  .gallery-card {
    box-shadow: var(--shadow-sm);
    transition: box-shadow 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .gallery-card:hover {
    box-shadow: var(--shadow-lg);
  }
  .gallery-image {
    transition: transform 1.2s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform;
  }
  .hover-overlay {
    transition: opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .zoom-icon {
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
</style>
